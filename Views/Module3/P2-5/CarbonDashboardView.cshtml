@using System.Text.Json
@model ProRental.Domain.Module3.P2_5.Entities.CarbonDashboardViewModel
@{
    ViewData["Title"] = "Carbon Dashboard";
    Layout = null;
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var productTrendJson = JsonSerializer.Serialize(Model?.ProductTrendline ?? [], jsonOptions);
    var productBarJson = JsonSerializer.Serialize(Model?.ProductBarChart ?? [], jsonOptions);
    var productPieJson = JsonSerializer.Serialize(Model?.ProductPieChart ?? [], jsonOptions);
    var staffTrendJson = JsonSerializer.Serialize(Model?.StaffTrendline ?? [], jsonOptions);
    var staffBarJson = JsonSerializer.Serialize(Model?.StaffBarChart ?? [], jsonOptions);
    var staffPieJson = JsonSerializer.Serialize(Model?.StaffPieChart ?? [], jsonOptions);
    var trendJson = JsonSerializer.Serialize(Model?.BuildingTrendline ?? [], jsonOptions);
    var barJson = JsonSerializer.Serialize(Model?.BuildingBarChart ?? [], jsonOptions);
    var pieJson = JsonSerializer.Serialize(Model?.BuildingPieChart ?? [], jsonOptions);
    var hotspotJson = JsonSerializer.Serialize(Model?.Hotspots ?? [], jsonOptions);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Carbon Dashboard - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .carbon-dashboard {
            background:
                radial-gradient(circle at top right, rgba(26, 147, 111, 0.18), transparent 28%),
                linear-gradient(180deg, #f4fbf8 0%, #edf7f2 100%);
            min-height: 100vh;
        }

        .dashboard-hero {
            background: linear-gradient(135deg, #113d2f 0%, #1a936f 55%, #2ec4b6 100%);
            border-radius: 1.5rem;
            overflow: hidden;
            position: relative;
        }

        .dashboard-hero::after {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            content: "";
            height: 18rem;
            position: absolute;
            right: -4rem;
            top: -6rem;
            width: 18rem;
        }

        .chart-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(17, 61, 47, 0.08);
        }

        .chart-shell {
            align-items: center;
            background: linear-gradient(180deg, #f8fcfa 0%, #eef7f2 100%);
            border: 2px dashed #b8d9c9;
            border-radius: 1rem;
            color: #4c6b5c;
            display: flex;
            flex-direction: column;
            font-weight: 600;
            gap: 0.5rem;
            justify-content: center;
            min-height: 240px;
            text-align: center;
        }

        .chart-shell i {
            color: #1a936f;
            font-size: 2rem;
        }

        .chart-shell small {
            max-width: 16rem;
        }

        .chart-shell-hotspot {
            min-height: 320px;
        }

        .chart-canvas-wrap {
            background: linear-gradient(180deg, #f8fcfa 0%, #eef7f2 100%);
            border: 1px solid #d8ebe0;
            border-radius: 1rem;
            padding: 1rem;
            position: relative;
        }

        .chart-canvas-wrap canvas {
            height: 100% !important;
            width: 100% !important;
        }

        .chart-canvas-wrap-lg {
            min-height: 320px;
        }

        .chart-canvas-wrap-md {
            min-height: 260px;
        }

        .chart-canvas-wrap-hotspot {
            min-height: 320px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/CarbonMonitoring/CarbonDashboardView">Carbon Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/CarbonFootprint/BuildingFootprintView">Building Footprint</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="#" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-dashboard py-5">
        <div class="container">
            <div class="dashboard-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Carbon Dashboard</h1>
                        <p class="lead mb-0 text-white-50">
                            Scaffold page for footprint trendlines, distribution charts, and carbon hotspot monitoring.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h6 mb-3">Debug Summary</h2>
                    <div class="row g-3 text-muted small">
                        <div class="col-md-3">
                            <strong>Product trend:</strong> @(Model?.ProductTrendline.Count ?? 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Product bars:</strong> @(Model?.ProductBarChart.Count ?? 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Staff trend:</strong> @(Model?.StaffTrendline.Count ?? 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Staff bars:</strong> @(Model?.StaffBarChart.Count ?? 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Trend points:</strong> @(Model?.BuildingTrendline.Count ?? 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Bar points:</strong> @(Model?.BuildingBarChart.Count ?? 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Pie points:</strong> @(Model?.BuildingPieChart.Count ?? 0)
                        </div>
                        <div class="col-md-3">
                            <strong>Hotspots:</strong> @(Model?.Hotspots.Count ?? 0)
                        </div>
                    </div>
                    @if ((Model?.BuildingTrendline.Count ?? 0) == 0)
                    {
                        <div class="alert alert-warning mt-3 mb-0">
                            No building chart data reached the view. Check the `buildingfootprint` table contents and the database connection in `appsettings.json`.
                        </div>
                    }
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Product Carbon Charts</h2>
                    <p class="text-muted mb-4">Live charts from `ProductFootprint.calculatedAt` and `totalCo2`.</p>
                    <div class="row g-4">
                        <div class="col-lg-12">
                            <div class="chart-canvas-wrap chart-canvas-wrap-lg">
                                <canvas id="productTrendlineChart"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-7">
                            <div class="chart-canvas-wrap chart-canvas-wrap-md">
                                <canvas id="productBarChart"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="chart-canvas-wrap chart-canvas-wrap-md">
                                <canvas id="productPieChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Building Carbon Charts</h2>
                    <p class="text-muted mb-4">Live charts from `BuildingFootprint.timeHourly` and `totalRoomCo2`.</p>
                    <div class="row g-4">
                        <div class="col-lg-12">
                            <div class="chart-canvas-wrap chart-canvas-wrap-lg">
                                <canvas id="buildingTrendlineChart"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-7">
                            <div class="chart-canvas-wrap chart-canvas-wrap-md">
                                <canvas id="buildingBarChart"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="chart-canvas-wrap chart-canvas-wrap-md">
                                <canvas id="buildingPieChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Staff Carbon Charts</h2>
                    <p class="text-muted mb-4">Live charts from `StaffFootprint.time` and `totalStaffCo2`.</p>
                    <div class="row g-4">
                        <div class="col-lg-12">
                            <div class="chart-canvas-wrap chart-canvas-wrap-lg">
                                <canvas id="staffTrendlineChart"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-7">
                            <div class="chart-canvas-wrap chart-canvas-wrap-md">
                                <canvas id="staffBarChart"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-5">
                            <div class="chart-canvas-wrap chart-canvas-wrap-md">
                                <canvas id="staffPieChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card chart-card">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Carbon Hotspot Chart</h2>
                    <p class="text-muted mb-4">Summary of total carbon footprint across product, building, and staff.</p>
                    @if (Model?.HotspotAlerts.Count > 0)
                    {
                        <div id="hotspotThresholdAlert" class="alert alert-warning" role="alert">
                            @string.Join(" ", Model.HotspotAlerts)
                        </div>
                    }
                    <div class="chart-canvas-wrap chart-canvas-wrap-hotspot">
                        <canvas id="hotspotChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="modal fade" id="hotspotThresholdModal" tabindex="-1" aria-labelledby="hotspotThresholdModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-warning-subtle">
                    <h5 class="modal-title" id="hotspotThresholdModalLabel">CO2 Threshold Reached</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">The following hotspot segments exceeded their CO2 threshold:</p>
                    <ul id="hotspotThresholdList" class="mb-0">
                        @foreach (var alert in Model?.HotspotAlerts ?? [])
                        {
                            <li>@alert</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-dark text-light pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
                    </h5>
                    <p class="text-secondary small">
                        A unified order processing and inventory management platform for modern rental
                        operations - fast, efficient, and sustainable.
                    </p>
                    <p class="text-secondary small mb-0">
                        &copy; @DateTime.Now.Year Pro Rentals. All rights reserved.
                    </p>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="/" class="text-secondary text-decoration-none small">Home</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small">Carbon Dashboard</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Track My Order</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Contact Us</a></li>
                        <li class="mb-1"><a href="/Home/Privacy" class="text-secondary text-decoration-none small">Privacy Policy</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Modules</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-cart3 me-1"></i>Order Processing</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-boxes me-1"></i>Inventory Management</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small"><i class="bi bi-leaf me-1"></i>Carbon Footprint</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-bar-chart me-1"></i>Analytics &amp; Reports</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-shield-lock me-1"></i>Staff Portal</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Contact</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-geo-alt me-2"></i>123 Rental Avenue, Singapore 123456
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-telephone me-2"></i>+65 6123 4567
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-envelope me-2"></i>support@@prorentals.sg
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-clock me-2"></i>Mon - Fri, 9 AM - 6 PM SGT
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="border-secondary mt-3 mb-3" />
            <p class="text-center text-secondary small mb-0">
                Built with Bootstrap 5.3.3 - Pro Rentals Order Processing System v1.0 - 2026
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/chart.js/dist/chart.umd.js"></script>
    <script>
        const productTrendData = @Html.Raw(productTrendJson);
        const productBarData = @Html.Raw(productBarJson);
        const productPieData = @Html.Raw(productPieJson);
        const staffTrendData = @Html.Raw(staffTrendJson);
        const staffBarData = @Html.Raw(staffBarJson);
        const staffPieData = @Html.Raw(staffPieJson);
        const trendData = @Html.Raw(trendJson);
        const barData = @Html.Raw(barJson);
        const pieData = @Html.Raw(pieJson);
        const hotspotData = @Html.Raw(hotspotJson);

        console.log('Carbon dashboard data', {
            productTrendData,
            productBarData,
            productPieData,
            staffTrendData,
            staffBarData,
            staffPieData,
            trendData,
            barData,
            pieData,
            hotspotData
        });

        const palette = ['#1a936f', '#2ec4b6', '#ff9f1c', '#5b8e7d', '#0f4c3a', '#7bc8a4'];

        const chartTextColor = '#35584a';
        const gridColor = 'rgba(53, 88, 74, 0.12)';
        const axisTitleFont = { size: 16, weight: '700' };
        const tickFont = { size: 13, weight: '600' };
        const piePercentagePlugin = {
            id: 'piePercentagePlugin',
            afterDatasetsDraw(chart) {
                if (chart.config.type !== 'doughnut') {
                    return;
                }

                const { ctx } = chart;
                const dataset = chart.data.datasets[0];
                const meta = chart.getDatasetMeta(0);
                const total = dataset.data.reduce((sum, value) => sum + value, 0);

                if (!total) {
                    return;
                }

                ctx.save();
                ctx.fillStyle = '#ffffff';
                ctx.font = 'bold 14px sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';

                meta.data.forEach((slice, index) => {
                    const value = Number(dataset.data[index] ?? 0);
                    if (!value) {
                        return;
                    }

                    const percentage = ((value / total) * 100).toFixed(1) + '%';
                    const { x, y } = slice.tooltipPosition();
                    ctx.fillText(percentage, x, y);
                });

                ctx.restore();
            }
        };

        new Chart(document.getElementById('productTrendlineChart'), {
            type: 'line',
            data: {
                labels: productTrendData.map(item => item.label),
                datasets: [{
                    data: productTrendData.map(item => item.value),
                    borderColor: '#ff9f1c',
                    backgroundColor: 'rgba(255, 159, 28, 0.18)',
                    fill: true,
                    tension: 0.3,
                    borderWidth: 3,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Time', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor }
                    },
                    y: {
                        title: { display: true, text: 'CO2', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor },
                        beginAtZero: true
                    }
                }
            }
        });

        new Chart(document.getElementById('productBarChart'), {
            type: 'bar',
            data: {
                labels: productBarData.map(item => item.label),
                datasets: [{
                    data: productBarData.map(item => item.value),
                    backgroundColor: palette,
                    borderRadius: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Product', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { display: false }
                    },
                    y: {
                        title: { display: true, text: 'CO2', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor },
                        beginAtZero: true
                    }
                }
            }
        });

        new Chart(document.getElementById('productPieChart'), {
            type: 'doughnut',
            plugins: [piePercentagePlugin],
            data: {
                labels: productPieData.map(item => item.label),
                datasets: [{
                    data: productPieData.map(item => item.value),
                    backgroundColor: palette,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label(context) {
                                const value = Number(context.raw ?? 0);
                                const total = context.dataset.data.reduce((sum, item) => sum + Number(item), 0);
                                const percentage = total ? ((value / total) * 100).toFixed(1) : '0.0';
                                return `${context.label}: ${value} CO2 (${percentage}%)`;
                            }
                        }
                    }
                }
            }
        });

        new Chart(document.getElementById('buildingTrendlineChart'), {
            type: 'line',
            data: {
                labels: trendData.map(item => item.label),
                datasets: [{
                    label: 'Building CO2',
                    data: trendData.map(item => item.value),
                    borderColor: '#1a936f',
                    backgroundColor: 'rgba(26, 147, 111, 0.18)',
                    fill: true,
                    tension: 0.3,
                    borderWidth: 3,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Time', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor }
                    },
                    y: {
                        title: { display: true, text: 'CO2', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor },
                        beginAtZero: true
                    }
                }
            }
        });

        new Chart(document.getElementById('buildingBarChart'), {
            type: 'bar',
            data: {
                labels: barData.map(item => item.label),
                datasets: [{
                    label: 'CO2 by Zone',
                    data: barData.map(item => item.value),
                    backgroundColor: palette,
                    borderRadius: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Zone', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { display: false }
                    },
                    y: {
                        title: { display: true, text: 'CO2', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor },
                        beginAtZero: true
                    }
                }
            }
        });

        new Chart(document.getElementById('buildingPieChart'), {
            type: 'doughnut',
            plugins: [piePercentagePlugin],
            data: {
                labels: pieData.map(item => item.label),
                datasets: [{
                    data: pieData.map(item => item.value),
                    backgroundColor: palette,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label(context) {
                                const value = Number(context.raw ?? 0);
                                const total = context.dataset.data.reduce((sum, item) => sum + Number(item), 0);
                                const percentage = total ? ((value / total) * 100).toFixed(1) : '0.0';
                                return `${context.label}: ${value} CO2 (${percentage}%)`;
                            }
                        }
                    }
                }
            }
        });

        new Chart(document.getElementById('staffTrendlineChart'), {
            type: 'line',
            data: {
                labels: staffTrendData.map(item => item.label),
                datasets: [{
                    data: staffTrendData.map(item => item.value),
                    borderColor: '#5b8e7d',
                    backgroundColor: 'rgba(91, 142, 125, 0.18)',
                    fill: true,
                    tension: 0.3,
                    borderWidth: 3,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Time', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor }
                    },
                    y: {
                        title: { display: true, text: 'CO2', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor },
                        beginAtZero: true
                    }
                }
            }
        });

        new Chart(document.getElementById('staffBarChart'), {
            type: 'bar',
            data: {
                labels: staffBarData.map(item => item.label),
                datasets: [{
                    data: staffBarData.map(item => item.value),
                    backgroundColor: palette,
                    borderRadius: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Staff', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { display: false }
                    },
                    y: {
                        title: { display: true, text: 'CO2', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor },
                        beginAtZero: true
                    }
                }
            }
        });

        new Chart(document.getElementById('staffPieChart'), {
            type: 'doughnut',
            plugins: [piePercentagePlugin],
            data: {
                labels: staffPieData.map(item => item.label),
                datasets: [{
                    data: staffPieData.map(item => item.value),
                    backgroundColor: palette,
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label(context) {
                                const value = Number(context.raw ?? 0);
                                const total = context.dataset.data.reduce((sum, item) => sum + Number(item), 0);
                                const percentage = total ? ((value / total) * 100).toFixed(1) : '0.0';
                                return `${context.label}: ${value} CO2 (${percentage}%)`;
                            }
                        }
                    }
                }
            }
        });

        new Chart(document.getElementById('hotspotChart'), {
            type: 'bar',
            data: {
                labels: hotspotData.map(item => item.label),
                datasets: [{
                    data: hotspotData.map(item => item.value),
                    backgroundColor: ['#ff9f1c', '#ffbf69', '#2ec4b6', '#5b8e7d', '#1a936f'],
                    borderRadius: 10
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        title: { display: true, text: 'Total CO2', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { color: gridColor },
                        beginAtZero: true
                    },
                    y: {
                        title: { display: true, text: 'Segment', color: chartTextColor, font: axisTitleFont },
                        ticks: { color: chartTextColor, font: tickFont },
                        grid: { display: false }
                    }
                }
            }
        });

        @if (Model?.HotspotAlerts.Count > 0)
        {
            <text>
            new bootstrap.Modal(document.getElementById('hotspotThresholdModal')).show();
            </text>
        }
    </script>
</body>
</html>
