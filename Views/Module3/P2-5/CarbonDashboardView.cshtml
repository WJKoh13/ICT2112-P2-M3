                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-dashboard py-5">
        <div class="container">
            <div class="dashboard-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Carbon Dashboard</h1>
                        <p class="lead mb-0 text-white-50">
                            Track product, building, and staff emissions in one place with trendlines, comparisons, and hotspot alerts.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Product Carbon Charts</h2>
                    <p class="text-muted mb-4">Live charts from `ProductFootprint.calculatedAt` and `totalCo2`.</p>
                    <div class="row g-4">
                        <div class="col-lg-12"><div class="chart-canvas-wrap chart-canvas-wrap-lg"><canvas id="productTrendlineChart"></canvas></div></div>
                        <div class="col-lg-8"><div class="chart-canvas-wrap chart-canvas-wrap-md"><canvas id="productBarChart"></canvas></div></div>
                        <div class="col-lg-4"><div class="chart-canvas-wrap chart-canvas-wrap-sm"><canvas id="productPieChart"></canvas></div></div>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Building Carbon Charts</h2>
                    <p class="text-muted mb-4">Live charts from `BuildingFootprint.timeHourly` and `totalRoomCo2`.</p>
                    <div class="row g-4">
                        <div class="col-lg-12"><div class="chart-canvas-wrap chart-canvas-wrap-lg"><canvas id="buildingTrendlineChart"></canvas></div></div>
                        <div class="col-lg-7"><div class="chart-canvas-wrap chart-canvas-wrap-md"><canvas id="buildingBarChart"></canvas></div></div>
                        <div class="col-lg-5"><div class="chart-canvas-wrap chart-canvas-wrap-md"><canvas id="buildingPieChart"></canvas></div></div>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Staff Carbon Charts</h2>
                    <p class="text-muted mb-4">Live charts from `StaffFootprint.time` and `totalStaffCo2`.</p>
                    <div class="row g-4">
                        <div class="col-lg-12"><div class="chart-canvas-wrap chart-canvas-wrap-lg"><canvas id="staffTrendlineChart"></canvas></div></div>
                        <div class="col-lg-7"><div class="chart-canvas-wrap chart-canvas-wrap-md"><canvas id="staffBarChart"></canvas></div></div>
                        <div class="col-lg-5"><div class="chart-canvas-wrap chart-canvas-wrap-md"><canvas id="staffPieChart"></canvas></div></div>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Packaging Carbon Charts</h2>
                    <p class="text-muted mb-4">Footprint totals by packaging material across all orders.</p>
                    <div class="row g-4">
                        <div class="col-lg-8"><div class="chart-canvas-wrap chart-canvas-wrap-md"><canvas id="packagingBarChart"></canvas></div></div>
                        <div class="col-lg-4"><div class="chart-canvas-wrap chart-canvas-wrap-sm"><canvas id="packagingPieChart"></canvas></div></div>
                    </div>
                </div>
            </div>

            <div class="card chart-card">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Carbon Hotspot Chart</h2>
                    <p class="text-muted mb-4">Summary of total carbon footprint across product, building, staff, and packaging.</p>
                    @if (Model?.HotspotAlerts.Count > 0)
                    {
                        <div id="hotspotThresholdAlert" class="alert alert-danger" role="alert">
                            @foreach (var alert in Model.HotspotAlerts)
                            {
                                <div>@alert</div>
                            }
                        </div>
                    }
                    <div class="chart-canvas-wrap chart-canvas-wrap-hotspot">
                        <canvas id="hotspotChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="modal fade" id="hotspotThresholdModal" tabindex="-1" aria-labelledby="hotspotThresholdModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="hotspotThresholdModalLabel">CO2 Threshold Reached</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2">The following hotspot segments exceeded their CO2 threshold:</p>
                    <ul id="hotspotThresholdList" class="mb-0">
                        @foreach (var alert in Model?.HotspotAlerts ?? [])
                        {
                            <li>@alert</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

