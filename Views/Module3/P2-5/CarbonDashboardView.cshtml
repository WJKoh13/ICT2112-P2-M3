                            <li><a class="dropdown-item" href="#"><i class="bi bi-recycle me-2" style="color: #0a9396;"></i>Return Process Carbon Lifecycle</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-collection me-2" style="color: #0a9396;"></i>Batch Delivery Consolidation</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/CarbonFootprint/BuildingFootprintView">Building Footprint</a>
                    </li>
                </ul>

                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
