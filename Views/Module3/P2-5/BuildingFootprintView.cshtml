    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script>
        const zoneWeights = {
            'North': 1.00,
            'South': 1.25,
            'East': 1.10,
            'West': 1.15,
            'Central': 1.35
        };

        const floorWeights = {
            'Level 1': 1.00,
            'Level 2': 1.20,
            'Level 3': 1.45,
            'Level 4': 1.60,
            'Level 5': 1.75
        };

        const form = document.getElementById('buildingFootprintForm');
        const feedbackBanner = document.getElementById('feedbackBanner');
        const resultsSection = document.getElementById('resultsSection');
        const roomResults = document.getElementById('roomResults');
        const totalResult = document.getElementById('totalResult');
        const buildingRecordsBody = document.getElementById('buildingRecordsBody');
        const cancelEditBtn = document.getElementById('cancelEditBtn');
        const refreshBuildingListBtn = document.getElementById('refreshBuildingListBtn');
        const buildingSortBy = document.getElementById('buildingSortBy');
        const CALIBRATION_CONSTANT = 0.000729;
        let editingBuildingFootprintId = null;

        function clearFieldError(fieldName) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = '';
        }

        function setFieldError(fieldName, message) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = message;
        }

        function setFeedback(message, type) {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'block';
            feedbackBanner.className = type === 'success' ? 'alert alert-success' : 'alert alert-danger';
            feedbackBanner.textContent = message;
        }

        function setInfoFeedback(message) {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'block';
            feedbackBanner.className = 'alert alert-info';
            feedbackBanner.textContent = message;
        }

        function resetFeedback() {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'none';
            feedbackBanner.textContent = '';
        }

        function sanitiseInput(value) {
            return value.toString().trim();
        }

        function hideCalculationBreakdown() {
            if (resultsSection) resultsSection.style.display = 'none';
            if (roomResults) roomResults.innerHTML = '';
            if (totalResult) totalResult.textContent = '0.00 kg CO2';
        }

        function setCreateMode() {
            editingBuildingFootprintId = null;
            const btn = document.getElementById('calculateBtn');
            btn.innerHTML = '<i class="bi bi-calculator me-2"></i>Calculate & Save Footprint';
            cancelEditBtn.style.display = 'none';
        }

        function setEditMode(record) {
            editingBuildingFootprintId = record.buildingCarbonFootprintId;
            const btn = document.getElementById('calculateBtn');
            btn.innerHTML = '<i class="bi bi-pencil-square me-2"></i>Update & Save Footprint';
            cancelEditBtn.style.display = 'inline-block';

            document.getElementById('zone').value = record.zone;
            document.getElementById('floor').value = record.floor;
            document.getElementById('block').value = record.block || '';
            document.getElementById('room').value = record.room || '';
            document.getElementById('roomSize').value = '';
            document.getElementById('co2Level').value = '';
            hideCalculationBreakdown();
            setInfoFeedback(`Editing record #${record.buildingCarbonFootprintId}. Re-enter Room Size and CO2 Level, then update.`);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function renderCalculationBreakdown(validation) {
            const zoneWeight = zoneWeights[validation.zone];
            const floorWeight = floorWeights[validation.floor];
            const weightedProduct = validation.roomSize * validation.co2Level * zoneWeight * floorWeight;
            const rawCo2 = weightedProduct * CALIBRATION_CONSTANT;
            const roundedCo2 = parseFloat(rawCo2.toFixed(2));

            roomResults.innerHTML = `
                <p class="mb-2"><strong>Location:</strong> Block ${validation.block}, Room ${validation.room} (${validation.zone}, ${validation.floor})</p>
                <div class="calc-line"><span class="calc-step-label">Formula</span>BF = Sr x Cr x Wz x Wf x k</div>
                <div class="calc-line"><span class="calc-step-label">Substitute</span>= ${validation.roomSize} x ${validation.co2Level} x ${zoneWeight.toFixed(2)} x ${floorWeight.toFixed(2)} x ${CALIBRATION_CONSTANT}</div>
                <div class="calc-line"><span class="calc-step-label">Step 1</span>${validation.roomSize} x ${validation.co2Level} x ${zoneWeight.toFixed(2)} x ${floorWeight.toFixed(2)} = ${weightedProduct.toFixed(4)}</div>
                <div class="calc-line"><span class="calc-step-label">Step 2</span>${weightedProduct.toFixed(4)} x ${CALIBRATION_CONSTANT} = ${rawCo2.toFixed(6)}</div>
                <div class="calc-line mb-0"><span class="calc-step-label">Final</span>Rounded to 2 d.p. = <strong>${roundedCo2.toFixed(2)} kg CO2</strong></div>
            `;

            totalResult.textContent = `${roundedCo2.toFixed(2)} kg CO2`;
            resultsSection.style.display = 'block';

            return roundedCo2;
        }

        function theValidate() {
            let isValid = true;

            const roomSizeRaw = sanitiseInput(document.getElementById('roomSize').value);
            const co2LevelRaw = sanitiseInput(document.getElementById('co2Level').value);
            const blockRaw = sanitiseInput(document.getElementById('block').value).toUpperCase();
            const roomRaw = sanitiseInput(document.getElementById('room').value).replace(/\s+/g, '');
            const zoneValue = document.getElementById('zone').value;
            const floorValue = document.getElementById('floor').value;

            clearFieldError('roomSize');
            clearFieldError('co2Level');
            clearFieldError('block');
            clearFieldError('room');
            clearFieldError('zone');
            clearFieldError('floor');

            const roomSize = parseFloat(roomSizeRaw);
            if (isNaN(roomSize) || roomSize <= 0) {
                setFieldError('roomSize', 'Room size must be a positive number');
                isValid = false;
            }

            const co2Level = parseFloat(co2LevelRaw);
            if (isNaN(co2Level) || co2Level <= 0) {
                setFieldError('co2Level', 'CO2 level must be a positive number');
                isValid = false;
            }

            if (!/^[A-Z]$/.test(blockRaw)) {
                setFieldError('block', 'Block must be a single letter (A-Z)');
                isValid = false;
            }

            if (!/^\d+$/.test(roomRaw) || parseInt(roomRaw, 10) <= 0) {
                setFieldError('room', 'Room must contain numbers only');
                isValid = false;
            }

            if (!Object.prototype.hasOwnProperty.call(zoneWeights, zoneValue)) {
                setFieldError('zone', 'Please select a zone');
                isValid = false;
            }

            if (!Object.prototype.hasOwnProperty.call(floorWeights, floorValue)) {
                setFieldError('floor', 'Please select a floor');
                isValid = false;
            }

            return {
                isValid,
                roomSize: roomSize,
                co2Level: co2Level,
                block: blockRaw,
                room: roomRaw,
                zone: zoneValue,
                floor: floorValue
            };
        }

        function formatSavedAt(dateValue) {
            const date = new Date(dateValue);
            if (isNaN(date.getTime())) return 'N/A';
            return date.toLocaleString(undefined, {
                year: 'numeric',
                month: 'short',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });
        }

        function sortBuildingRecords(records) {
            const selectedSort = buildingSortBy?.value || 'id';
            const sorted = [...records];

            sorted.sort((a, b) => {
                if (selectedSort === 'zone') {
                    return (a.zone || '').localeCompare(b.zone || '');
                }
                if (selectedSort === 'block') {
                    return (a.block || '').localeCompare(b.block || '');
                }
                if (selectedSort === 'floor') {
                    return (a.floor || '').localeCompare(b.floor || '');
                }
                if (selectedSort === 'savedAtOldest') {
                    return new Date(a.timehourly).getTime() - new Date(b.timehourly).getTime();
                }
                if (selectedSort === 'savedAtNewest') {
                    return new Date(b.timehourly).getTime() - new Date(a.timehourly).getTime();
                }

                return (a.buildingCarbonFootprintId || 0) - (b.buildingCarbonFootprintId || 0);
            });

            return sorted;
        }

        function createEmptyRow(message) {
            return `<tr><td colspan="8" class="text-center text-muted py-4">${message}</td></tr>`;
        }

        async function loadBuildingRecords() {
            try {
                buildingRecordsBody.innerHTML = createEmptyRow('Loading records...');
                const response = await fetch('/api/building-footprint');
                if (!response.ok) {
                    throw new Error('Unable to load building footprint records');
                }

                const records = await response.json();
                if (!Array.isArray(records) || records.length === 0) {
                    buildingRecordsBody.innerHTML = createEmptyRow('No building footprint records yet.');
                    return;
                }

                const sortedRecords = sortBuildingRecords(records);
                buildingRecordsBody.innerHTML = sortedRecords.map(record => `
                    <tr>
                        <td>${record.buildingCarbonFootprintId}</td>
                        <td>${record.zone ?? ''}</td>
                        <td>${record.block ?? ''}</td>
                        <td>${record.floor ?? ''}</td>
                        <td>${record.room ?? ''}</td>
                        <td>${Number(record.totalRoomCo2).toFixed(2)} kg CO2</td>
                        <td>${formatSavedAt(record.timehourly)}</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-outline-primary btn-sm me-1 edit-building-btn"
                                data-id="${record.buildingCarbonFootprintId}"
                                data-zone="${record.zone ?? ''}"
                                data-block="${record.block ?? ''}"
                                data-floor="${record.floor ?? ''}"
                                data-room="${record.room ?? ''}">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm delete-building-btn"
                                data-id="${record.buildingCarbonFootprintId}">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                buildingRecordsBody.innerHTML = createEmptyRow(error.message || 'Unable to load records.');
            }
        }

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            resetFeedback();

            const validation = theValidate();

            if (!validation.isValid) {
                hideCalculationBreakdown();
                setFeedback('Please fix the errors below and resubmit.', 'error');
                return;
            }

            const totalRoomCo2 = renderCalculationBreakdown(validation);

            const body = {
                roomSize: validation.roomSize,
                co2Level: validation.co2Level,
                zone: validation.zone,
                block: validation.block,
                floor: validation.floor,
                room: validation.room,
                totalRoomCo2: totalRoomCo2
            };

            const btn = document.getElementById('calculateBtn');
            const initialBtnHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Saving...';

            try {
                const isEditing = editingBuildingFootprintId !== null;
                const endpoint = isEditing
                    ? `/api/building-footprint/${editingBuildingFootprintId}`
                    : '/api/building-footprint';

                const response = await fetch(endpoint, {
                    method: isEditing ? 'PUT' : 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(body)
                });

                if (!response.ok) {
                    let err = 'Unable to save footprint';
                    try {
                        const data = await response.json();
                        err = data.error || data.message || err;
                    } catch {
                        // ignore JSON parse errors
                    }
                    throw new Error(err);
                }

                setFeedback(
                    isEditing
                        ? `Footprint updated - totalRoomCo2: ${totalRoomCo2.toFixed(2)} kg CO2`
                        : `Footprint saved - totalRoomCo2: ${totalRoomCo2.toFixed(2)} kg CO2`,
                    'success');
                document.querySelectorAll('.text-danger').forEach(el => el.textContent = '');
                form.reset();
                setCreateMode();
                await loadBuildingRecords();
            } catch (error) {
                setFeedback(error.message || 'An unexpected error occurred.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = initialBtnHtml;
            }
        });

        document.querySelectorAll('#roomSize, #co2Level, #block, #room, #zone, #floor').forEach(input => {
            input.addEventListener('input', () => {
                clearFieldError(input.id);
                resetFeedback();
                hideCalculationBreakdown();
            });
        });

        cancelEditBtn.addEventListener('click', () => {
            form.reset();
            setCreateMode();
            resetFeedback();
            hideCalculationBreakdown();
            document.querySelectorAll('.text-danger').forEach(el => el.textContent = '');
        });

        refreshBuildingListBtn.addEventListener('click', () => {
            loadBuildingRecords();
        });

        buildingSortBy.addEventListener('change', () => {
            loadBuildingRecords();
        });

        buildingRecordsBody.addEventListener('click', async (event) => {
            const editBtn = event.target.closest('.edit-building-btn');
            const deleteBtn = event.target.closest('.delete-building-btn');

            if (editBtn) {
                setEditMode({
                    buildingCarbonFootprintId: parseInt(editBtn.dataset.id, 10),
                    zone: editBtn.dataset.zone,
                    block: editBtn.dataset.block,
                    floor: editBtn.dataset.floor,
                    room: editBtn.dataset.room
                });
                return;
            }

            if (!deleteBtn) {
                return;
            }

            const id = parseInt(deleteBtn.dataset.id, 10);
            if (!confirm(`Delete building footprint record #${id}?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/building-footprint/${id}`, {
                    method: 'DELETE'
                });

                if (!response.ok) {
                    let err = 'Unable to delete record';
                    try {
                        const data = await response.json();
                        err = data.error || data.message || err;
                    } catch {
                        // ignore JSON parse errors
                    }
                    throw new Error(err);
                }

                if (editingBuildingFootprintId === id) {
                    form.reset();
                    setCreateMode();
                    hideCalculationBreakdown();
                }

                setFeedback(`Deleted building footprint record #${id}.`, 'success');
                await loadBuildingRecords();
            } catch (error) {
                setFeedback(error.message || 'An unexpected error occurred.', 'error');
            }
        });

        setCreateMode();
        loadBuildingRecords();
    </script>
</body>
</html>


