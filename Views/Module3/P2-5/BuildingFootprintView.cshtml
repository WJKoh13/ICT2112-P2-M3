@{
    ViewData["Title"] = "Building Footprint";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Building Footprint - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .carbon-dashboard {
            background:
                radial-gradient(circle at top right, rgba(26, 147, 111, 0.18), transparent 28%),
                linear-gradient(180deg, #f4fbf8 0%, #edf7f2 100%);
            min-height: 100vh;
        }

        .dashboard-hero {
            background: linear-gradient(135deg, #113d2f 0%, #1a936f 55%, #2ec4b6 100%);
            border-radius: 1.5rem;
            overflow: hidden;
            position: relative;
        }

        .dashboard-hero::after {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            content: "";
            height: 18rem;
            position: absolute;
            right: -4rem;
            top: -6rem;
            width: 18rem;
        }

        .chart-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(17, 61, 47, 0.08);
        }

        .chart-shell {
            align-items: center;
            background: linear-gradient(180deg, #f8fcfa 0%, #eef7f2 100%);
            border: 2px dashed #b8d9c9;
            border-radius: 1rem;
            color: #4c6b5c;
            display: flex;
            flex-direction: column;
            font-weight: 600;
            gap: 0.5rem;
            justify-content: center;
            min-height: 240px;
            text-align: center;
        }

        .chart-shell i {
            color: #1a936f;
            font-size: 2rem;
        }

        .chart-shell small {
            max-width: 16rem;
        }

        .chart-shell-hotspot {
            min-height: 320px;
        }

        .form-align-row .col-lg-6 {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .form-align-row .form-control,
        .form-align-row .form-select {
            min-height: 44px;
        }

        .form-align-row .mb-3 {
            margin-bottom: 1rem;
        }

        .calc-line {
            background: #f8fcfa;
            border: 1px solid #d9ece2;
            border-radius: 0.75rem;
            font-family: "Consolas", "Courier New", monospace;
            font-size: 0.95rem;
            margin-bottom: 0.75rem;
            padding: 0.75rem 0.9rem;
        }

        .calc-step-label {
            color: #1a936f;
            font-weight: 700;
            margin-right: 0.5rem;
        }

        .bf-total-card {
            background: linear-gradient(135deg, #0f5f46 0%, #1a936f 100%);
            border: 1px solid #0d6a4d;
        }

        .bf-total-card h6,
        .bf-total-card h3,
        .bf-total-card small {
            color: #ffffff !important;
        }

        .bf-total-card small {
            opacity: 0.92;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/CarbonMonitoring/CarbonDashboardView">Carbon Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/CarbonMonitoring/BuildingFootprintView">Building Footprint</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="#" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-dashboard py-5">
        <div class="container">
            <div class="dashboard-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Building Footprint Analysis</h1>
                        <p class="lead mb-0 text-white-50">
                            Detailed building carbon footprint metrics, trendlines, and environmental impact data.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Formula: Building Footprint Calculation</h2>
                    <p class="text-muted mb-4">
                        <strong>BF = Σ(Sr × Cr × Wz × Wf)</strong><br/>
                        <small>Where Sr = Room Size, Cr = CO₂ Level, Wz = Zone Weight, Wf = Floor Weight</small>
                    </p>

                    <form id="buildingFootprintForm">
                        <div class="row g-3 mb-4 form-align-row">
                            <div class="col-12">
                                <h5 class="text-success mb-3">Room Inputs</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="roomSize" class="form-label">Room Size (Sr) - m²</label>
                                            <input type="text" class="form-control room-input" id="roomSize" placeholder="e.g., 50" required />
                                            <div id="roomSizeError" class="text-danger small mt-1" aria-live="polite"></div>
                                            <small class="text-muted">Bigger rooms → larger contribution</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="co2Level" class="form-label">CO₂ Level (Cr) - ppm</label>
                                            <input type="text" class="form-control room-input" id="co2Level" placeholder="e.g., 400" required />
                                            <div id="co2LevelError" class="text-danger small mt-1" aria-live="polite"></div>
                                            <small class="text-muted">Higher CO₂ → more activity → high contribution</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <h5 class="text-success mb-3">Location Inputs</h5>
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="zone" class="form-label">Zone</label>
                                            <select class="form-select room-input" id="zone" required>
                                                <option value="">-- Select Zone --</option>
                                                <option value="North">North (1.00)</option>
                                                <option value="South">South (1.25)</option>
                                                <option value="East">East (1.10)</option>
                                                <option value="West">West (1.15)</option>
                                                <option value="Central">Central (1.35)</option>
                                            </select>
                                            <div id="zoneError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="floor" class="form-label">Floor</label>
                                            <select class="form-select room-input" id="floor" required>
                                                <option value="">-- Select Floor --</option>
                                                <option value="Level 1">Level 1 (1.00)</option>
                                                <option value="Level 2">Level 2 (1.20)</option>
                                                <option value="Level 3">Level 3 (1.45)</option>
                                                <option value="Level 4">Level 4 (1.60)</option>
                                                <option value="Level 5">Level 5 (1.75)</option>
                                            </select>
                                            <div id="floorError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="block" class="form-label">Block</label>
                                            <input type="text" class="form-control room-input" id="block" placeholder="e.g., A" required />
                                            <div id="blockError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="room" class="form-label">Room</label>
                                            <input type="number" class="form-control room-input" id="room" placeholder="e.g., 101" min="1" step="1" inputmode="numeric" required />
                                            <div id="roomError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col">
                                <button type="submit" id="calculateBtn" class="btn btn-success">
                                    <i class="bi bi-calculator me-2"></i>Calculate & Save Footprint
                                </button>
                            </div>
                        </div>

                        <div id="feedbackBanner" role="status" class="mb-3" style="display:none"></div>
                    </form>

                    <!-- Results Section -->
                    <div id="resultsSection" style="display: none;" class="mt-4 pt-4 border-top">
                        <h4 class="text-success mb-3">Calculation Results</h4>
                        <div class="row">
                            <div class="col-12 mb-3">
                                <div class="alert alert-success bf-total-card">
                                    <h6 class="text-white mb-2">Total Building Footprint (BF)</h6>
                                    <h3 class="text-white mb-0" id="totalResult">0.00 kg CO2</h3>
                                    <small class="text-white-50">Calculated value for this room submission</small>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="alert alert-light border border-success">
                                    <h6 class="text-success mb-2">How This Was Calculated</h6>
                                    <div id="roomResults"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-light pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
                    </h5>
                    <p class="text-secondary small">
                        A unified order processing and inventory management platform for modern rental
                        operations - fast, efficient, and sustainable.
                    </p>
                    <p class="text-secondary small mb-0">
                        &copy; @DateTime.Now.Year Pro Rentals. All rights reserved.
                    </p>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="/" class="text-secondary text-decoration-none small">Home</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small">Carbon Dashboard</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/BuildingFootprintView" class="text-secondary text-decoration-none small">Building Footprint</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Track My Order</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Contact Us</a></li>
                        <li class="mb-1"><a href="/Home/Privacy" class="text-secondary text-decoration-none small">Privacy Policy</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Modules</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-cart3 me-1"></i>Order Processing</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-boxes me-1"></i>Inventory Management</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small"><i class="bi bi-leaf me-1"></i>Carbon Footprint</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-bar-chart me-1"></i>Analytics &amp; Reports</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-shield-lock me-1"></i>Staff Portal</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Contact</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-geo-alt me-2"></i>123 Rental Avenue, Singapore 123456
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-telephone me-2"></i>+65 6123 4567
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-envelope me-2"></i>support@@prorentals.sg
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-clock me-2"></i>Mon - Fri, 9 AM - 6 PM SGT
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="border-secondary mt-3 mb-3" />
            <p class="text-center text-secondary small mb-0">
                Built with Bootstrap 5.3.3 - Pro Rentals Order Processing System v1.0 - 2026
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const zoneWeights = {
            'North': 1.00,
            'South': 1.25,
            'East': 1.10,
            'West': 1.15,
            'Central': 1.35
        };

        const floorWeights = {
            'Level 1': 1.00,
            'Level 2': 1.20,
            'Level 3': 1.45,
            'Level 4': 1.60,
            'Level 5': 1.75
        };

        const form = document.getElementById('buildingFootprintForm');
        const feedbackBanner = document.getElementById('feedbackBanner');
        const resultsSection = document.getElementById('resultsSection');
        const roomResults = document.getElementById('roomResults');
        const totalResult = document.getElementById('totalResult');
        const CALIBRATION_CONSTANT = 0.000729;

        function clearFieldError(fieldName) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = '';
        }

        function setFieldError(fieldName, message) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = message;
        }

        function setFeedback(message, type) {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'block';
            feedbackBanner.className = type === 'success' ? 'alert alert-success' : 'alert alert-danger';
            feedbackBanner.textContent = message;
        }

        function resetFeedback() {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'none';
            feedbackBanner.textContent = '';
        }

        function sanitiseInput(value) {
            return value.toString().trim();
        }

        function hideCalculationBreakdown() {
            if (resultsSection) resultsSection.style.display = 'none';
            if (roomResults) roomResults.innerHTML = '';
            if (totalResult) totalResult.textContent = '0.00 kg CO2';
        }

        function renderCalculationBreakdown(validation) {
            const zoneWeight = zoneWeights[validation.zone];
            const floorWeight = floorWeights[validation.floor];
            const weightedProduct = validation.roomSize * validation.co2Level * zoneWeight * floorWeight;
            const rawCo2 = weightedProduct * CALIBRATION_CONSTANT;
            const roundedCo2 = parseFloat(rawCo2.toFixed(2));

            roomResults.innerHTML = `
                <p class="mb-2"><strong>Location:</strong> Block ${validation.block}, Room ${validation.room} (${validation.zone}, ${validation.floor})</p>
                <div class="calc-line"><span class="calc-step-label">Formula</span>BF = Sr x Cr x Wz x Wf x k</div>
                <div class="calc-line"><span class="calc-step-label">Substitute</span>= ${validation.roomSize} x ${validation.co2Level} x ${zoneWeight.toFixed(2)} x ${floorWeight.toFixed(2)} x ${CALIBRATION_CONSTANT}</div>
                <div class="calc-line"><span class="calc-step-label">Step 1</span>${validation.roomSize} x ${validation.co2Level} x ${zoneWeight.toFixed(2)} x ${floorWeight.toFixed(2)} = ${weightedProduct.toFixed(4)}</div>
                <div class="calc-line"><span class="calc-step-label">Step 2</span>${weightedProduct.toFixed(4)} x ${CALIBRATION_CONSTANT} = ${rawCo2.toFixed(6)}</div>
                <div class="calc-line mb-0"><span class="calc-step-label">Final</span>Rounded to 2 d.p. = <strong>${roundedCo2.toFixed(2)} kg CO2</strong></div>
            `;

            totalResult.textContent = `${roundedCo2.toFixed(2)} kg CO2`;
            resultsSection.style.display = 'block';

            return roundedCo2;
        }

        function theValidate() {
            let isValid = true;

            let roomSizeRaw = sanitiseInput(document.getElementById('roomSize').value);
            let co2LevelRaw = sanitiseInput(document.getElementById('co2Level').value);
            let blockRaw = sanitiseInput(document.getElementById('block').value).toUpperCase();
            let roomRaw = sanitiseInput(document.getElementById('room').value).replace(/\s+/g, '');
            let zoneValue = document.getElementById('zone').value;
            let floorValue = document.getElementById('floor').value;

            clearFieldError('roomSize');
            clearFieldError('co2Level');
            clearFieldError('block');
            clearFieldError('room');
            clearFieldError('zone');
            clearFieldError('floor');

            const roomSize = parseFloat(roomSizeRaw);
            if (isNaN(roomSize) || roomSize <= 0) {
                setFieldError('roomSize', 'Room size must be a positive number');
                isValid = false;
            }

            const co2Level = parseFloat(co2LevelRaw);
            if (isNaN(co2Level) || co2Level <= 0) {
                setFieldError('co2Level', 'CO₂ level must be a positive number');
                isValid = false;
            }

            if (!/^[A-Z]$/.test(blockRaw)) {
                setFieldError('block', 'Block must be a single letter (A–Z)');
                isValid = false;
            }

            if (!/^\d+$/.test(roomRaw) || parseInt(roomRaw, 10) <= 0) {
                setFieldError('room', 'Room must contain numbers only');
                isValid = false;
            }

            if (!zoneWeights.hasOwnProperty(zoneValue)) {
                setFieldError('zone', 'Please select a zone');
                isValid = false;
            }

            if (!floorWeights.hasOwnProperty(floorValue)) {
                setFieldError('floor', 'Please select a floor');
                isValid = false;
            }

            return {
                isValid,
                roomSize: roomSize,
                co2Level: co2Level,
                block: blockRaw,
                room: roomRaw,
                zone: zoneValue,
                floor: floorValue
            };
        }

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            resetFeedback();

            const validation = theValidate();

            if (!validation.isValid) {
                hideCalculationBreakdown();
                setFeedback('Please fix the errors below and resubmit.', 'error');
                return;
            }

            const totalRoomCo2 = renderCalculationBreakdown(validation);

            const body = {
                roomSize: validation.roomSize,
                co2Level: validation.co2Level,
                zone: validation.zone,
                block: validation.block,
                floor: validation.floor,
                room: validation.room,
                totalRoomCo2: totalRoomCo2
            };

            const btn = document.getElementById('calculateBtn');
            const initialBtnHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Saving...';

            try {
                const response = await fetch('/api/building-footprint', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(body)
                });

                if (!response.ok) {
                    let err = 'Unable to save footprint';
                    try {
                        const data = await response.json();
                        err = data.error || data.message || err;
                    } catch {
                        // ignore JSON parse errors
                    }
                    throw new Error(err);
                }

                setFeedback(`Footprint saved — totalRoomCo2: ${totalRoomCo2.toFixed(2)} kg CO₂`, 'success');
                document.querySelectorAll('.text-danger').forEach(el => el.textContent = '');

            } catch (error) {
                setFeedback(error.message || 'An unexpected error occurred.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = initialBtnHtml;
            }
        });

        // Clear errors whilst user types
        document.querySelectorAll('#roomSize, #co2Level, #block, #room, #zone, #floor').forEach(input => {
            input.addEventListener('input', () => {
                const fieldName = input.id;
                clearFieldError(fieldName);
                resetFeedback();
                hideCalculationBreakdown();
            });
        });
    </script>
</body>
</html>


