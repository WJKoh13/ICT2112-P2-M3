@{
    ViewData["Title"] = "Building Footprint";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Building Footprint - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .carbon-dashboard {
            background:
                radial-gradient(circle at top right, rgba(26, 147, 111, 0.18), transparent 28%),
                linear-gradient(180deg, #f4fbf8 0%, #edf7f2 100%);
            min-height: 100vh;
        }

        .dashboard-hero {
            background: linear-gradient(135deg, #113d2f 0%, #1a936f 55%, #2ec4b6 100%);
            border-radius: 1.5rem;
            overflow: hidden;
            position: relative;
        }

        .dashboard-hero::after {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            content: "";
            height: 18rem;
            position: absolute;
            right: -4rem;
            top: -6rem;
            width: 18rem;
        }

        .chart-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(17, 61, 47, 0.08);
        }

        .chart-shell {
            align-items: center;
            background: linear-gradient(180deg, #f8fcfa 0%, #eef7f2 100%);
            border: 2px dashed #b8d9c9;
            border-radius: 1rem;
            color: #4c6b5c;
            display: flex;
            flex-direction: column;
            font-weight: 600;
            gap: 0.5rem;
            justify-content: center;
            min-height: 240px;
            text-align: center;
        }

        .chart-shell i {
            color: #1a936f;
            font-size: 2rem;
        }

        .chart-shell small {
            max-width: 16rem;
        }

        .chart-shell-hotspot {
            min-height: 320px;
        }

        .form-align-row .col-lg-6 {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .form-align-row .form-control,
        .form-align-row .form-select {
            min-height: 44px;
        }

        .form-align-row .mb-3 {
            margin-bottom: 1rem;
        }

        .calc-line {
            background: #f8fcfa;
            border: 1px solid #d9ece2;
            border-radius: 0.75rem;
            font-family: "Consolas", "Courier New", monospace;
            font-size: 0.95rem;
            margin-bottom: 0.75rem;
            padding: 0.75rem 0.9rem;
        }

        .calc-step-label {
            color: #1a936f;
            font-weight: 700;
            margin-right: 0.5rem;
        }

        .bf-total-card {
            background: linear-gradient(135deg, #0f5f46 0%, #1a936f 100%);
            border: 1px solid #0d6a4d;
        }

        .bf-total-card h6,
        .bf-total-card h3,
        .bf-total-card small {
            color: #ffffff !important;
        }

        .bf-total-card small {
            opacity: 0.92;
        }

        .table-action-controls {
            align-items: flex-end;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .table-sort-control {
            min-width: 220px;
        }

        .table-sort-control .form-select {
            min-height: 38px;
        }

        @@media (max-width: 576px) {
            .table-sort-control {
                min-width: 100%;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/CarbonMonitoring/CarbonDashboardView">Carbon Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/CarbonMonitoring/BuildingFootprintView">Building Footprint</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="#" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-dashboard py-5">
        <div class="container">
            <div class="dashboard-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Building Footprint Analysis</h1>
                        <p class="lead mb-0 text-white-50">
                            Detailed building carbon footprint metrics, trendlines, and environmental impact data.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Formula: Building Footprint Calculation</h2>
                    <p class="text-muted mb-4">
                        <strong>BF = Σ(Sr × Cr × Wz × Wf)</strong><br/>
                        <small>Where Sr = Room Size, Cr = CO₂ Level, Wz = Zone Weight, Wf = Floor Weight</small>
                    </p>

                    <form id="buildingFootprintForm">
                        <div class="row g-3 mb-4 form-align-row">
                            <div class="col-12">
                                <h5 class="text-success mb-3">Room Inputs</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="roomSize" class="form-label">Room Size (Sr) - m²</label>
                                            <input type="text" class="form-control room-input" id="roomSize" placeholder="e.g., 50" required />
                                            <div id="roomSizeError" class="text-danger small mt-1" aria-live="polite"></div>
                                            <small class="text-muted">Bigger rooms → larger contribution</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <label for="co2Level" class="form-label">CO₂ Level (Cr) - ppm</label>
                                            <input type="text" class="form-control room-input" id="co2Level" placeholder="e.g., 400" required />
                                            <div id="co2LevelError" class="text-danger small mt-1" aria-live="polite"></div>
                                            <small class="text-muted">Higher CO₂ → more activity → high contribution</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <h5 class="text-success mb-3">Location Inputs</h5>
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="zone" class="form-label">Zone</label>
                                            <select class="form-select room-input" id="zone" required>
                                                <option value="">-- Select Zone --</option>
                                                <option value="North">North (1.00)</option>
                                                <option value="South">South (1.25)</option>
                                                <option value="East">East (1.10)</option>
                                                <option value="West">West (1.15)</option>
                                                <option value="Central">Central (1.35)</option>
                                            </select>
                                            <div id="zoneError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="floor" class="form-label">Floor</label>
                                            <select class="form-select room-input" id="floor" required>
                                                <option value="">-- Select Floor --</option>
                                                <option value="Level 1">Level 1 (1.00)</option>
                                                <option value="Level 2">Level 2 (1.20)</option>
                                                <option value="Level 3">Level 3 (1.45)</option>
                                                <option value="Level 4">Level 4 (1.60)</option>
                                                <option value="Level 5">Level 5 (1.75)</option>
                                            </select>
                                            <div id="floorError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="block" class="form-label">Block</label>
                                            <input type="text" class="form-control room-input" id="block" placeholder="e.g., A" required />
                                            <div id="blockError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="mb-3">
                                            <label for="room" class="form-label">Room</label>
                                            <input type="number" class="form-control room-input" id="room" placeholder="e.g., 101" min="1" step="1" inputmode="numeric" required />
                                            <div id="roomError" class="text-danger small mt-1" aria-live="polite"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-auto">
                                <button type="submit" id="calculateBtn" class="btn btn-success">
                                    <i class="bi bi-calculator me-2"></i>Calculate & Save Footprint
                                </button>
                            </div>
                            <div class="col-auto">
                                <button type="button" id="cancelEditBtn" class="btn btn-outline-secondary" style="display:none;">
                                    Cancel Edit
                                </button>
                            </div>
                        </div>

                        <div id="feedbackBanner" role="status" class="mb-3" style="display:none"></div>
                    </form>

                    <!-- Results Section -->
                    <div id="resultsSection" style="display: none;" class="mt-4 pt-4 border-top">
                        <h4 class="text-success mb-3">Calculation Results</h4>
                        <div class="row">
                            <div class="col-12 mb-3">
                                <div class="alert alert-success bf-total-card">
                                    <h6 class="text-white mb-2">Total Building Footprint (BF)</h6>
                                    <h3 class="text-white mb-0" id="totalResult">0.00 kg CO2</h3>
                                    <small class="text-white-50">Calculated value for this room submission</small>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="alert alert-light border border-success">
                                    <h6 class="text-success mb-2">How This Was Calculated</h6>
                                    <div id="roomResults"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                            <div>
                                <h4 class="text-success mb-1">Saved Building Footprints</h4>
                                <p class="text-muted mb-0">Create, update, and delete records on this same page.</p>
                            </div>
                            <div class="table-action-controls">
                                <div class="table-sort-control">
                                    <label for="buildingSortBy" class="form-label mb-1 small text-muted">Order by</label>
                                    <select id="buildingSortBy" class="form-select form-select-sm">
                                        <option value="id" selected>ID</option>
                                        <option value="zone">Zone (A-Z)</option>
                                        <option value="block">Block (A-Z)</option>
                                        <option value="floor">Floor</option>
                                        <option value="savedAtOldest">Saved At (Oldest-Newest)</option>
                                        <option value="savedAtNewest">Saved At (Newest-Oldest)</option>
                                    </select>
                                </div>
                                <button type="button" id="refreshBuildingListBtn" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                                </button>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead class="table-success">
                                    <tr>
                                        <th>ID</th>
                                        <th>Zone</th>
                                        <th>Block</th>
                                        <th>Floor</th>
                                        <th>Room</th>
                                        <th>Total CO2</th>
                                        <th>Saved At</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="buildingRecordsBody">
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">Loading records...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-light pt-5 pb-3">
