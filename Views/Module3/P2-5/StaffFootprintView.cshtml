@{
    ViewData["Title"] = "Staff Footprint";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staff Footprint - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .carbon-dashboard {
            background:
                radial-gradient(circle at top right, rgba(26, 147, 111, 0.18), transparent 28%),
                linear-gradient(180deg, #f4fbf8 0%, #edf7f2 100%);
            min-height: 100vh;
        }

        .dashboard-hero {
            background: linear-gradient(135deg, #113d2f 0%, #1a936f 55%, #2ec4b6 100%);
            border-radius: 1.5rem;
            overflow: hidden;
            position: relative;
        }

        .dashboard-hero::after {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            content: "";
            height: 18rem;
            position: absolute;
            right: -4rem;
            top: -6rem;
            width: 18rem;
        }

        .chart-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(17, 61, 47, 0.08);
        }

        .chart-shell {
            align-items: center;
            background: linear-gradient(180deg, #f8fcfa 0%, #eef7f2 100%);
            border: 2px dashed #b8d9c9;
            border-radius: 1rem;
            color: #4c6b5c;
            display: flex;
            flex-direction: column;
            font-weight: 600;
            gap: 0.5rem;
            justify-content: center;
            min-height: 240px;
            text-align: center;
        }

        .chart-shell i {
            color: #1a936f;
            font-size: 2rem;
        }

        .chart-shell small {
            max-width: 16rem;
        }

        .chart-shell-hotspot {
            min-height: 320px;
        }

        .form-align-row .form-control,
        .form-align-row .form-select {
            min-height: 44px;
        }

        .calc-line {
            background: #f8fcfa;
            border: 1px solid #d9ece2;
            border-radius: 0.75rem;
            font-family: "Consolas", "Courier New", monospace;
            font-size: 0.95rem;
            margin-bottom: 0.75rem;
            padding: 0.75rem 0.9rem;
        }

        .calc-step-label {
            color: #1a936f;
            font-weight: 700;
            margin-right: 0.5rem;
        }

        .sf-total-card {
            background: linear-gradient(135deg, #0f5f46 0%, #1a936f 100%);
            border: 1px solid #0d6a4d;
        }

        .sf-total-card h6,
        .sf-total-card h3,
        .sf-total-card small {
            color: #ffffff !important;
        }

        .sf-total-card small {
            opacity: 0.92;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/CarbonMonitoring/CarbonDashboardView">Carbon Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/CarbonFootprint/StaffFootprintView">Staff Footprint</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="#" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-dashboard py-5">
        <div class="container">
            <div class="dashboard-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Staff Footprint Analysis</h1>
                        <p class="lead mb-0 text-white-50">
                            Detailed staff carbon footprint metrics, trendlines, and environmental impact data.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Formula: Staff Footprint Calculation</h2>
                    <p class="text-muted mb-4">
                        <strong>SF = H x Er x Dw</strong><br />
                        <small>Where H = Hours Worked (Check-Out minus Check-In), Er = Emission Rate (3.53 kg CO2/hour), Dw = Department Weight</small>
                    </p>

                    <form id="staffFootprintForm">
                        <div class="row g-3 mb-4 form-align-row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="staffId" class="form-label">Staff ID</label>
                                    <select class="form-select" id="staffId" required>
                                        <option value="">-- Select Staff --</option>
                                    </select>
                                    <div id="staffIdError" class="text-danger small mt-1" aria-live="polite"></div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="checkInTime" class="form-label">Check-In Time</label>
                                    <input type="datetime-local" class="form-control" id="checkInTime" required />
                                    <div id="checkInTimeError" class="text-danger small mt-1" aria-live="polite"></div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="checkOutTime" class="form-label">Check-Out Time</label>
                                    <input type="datetime-local" class="form-control" id="checkOutTime" required />
                                    <div id="checkOutTimeError" class="text-danger small mt-1" aria-live="polite"></div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col">
                                <button type="submit" id="calculateBtn" class="btn btn-success">
                                    <i class="bi bi-calculator me-2"></i>Calculate & Save Footprint
                                </button>
                            </div>
                        </div>

                        <div id="feedbackBanner" role="status" class="mb-3" style="display:none"></div>
                    </form>

                    <div id="resultsSection" style="display: none;" class="mt-4 pt-4 border-top">
                        <h4 class="text-success mb-3">Calculation Results</h4>
                        <div class="row">
                            <div class="col-12 mb-3">
                                <div class="alert alert-success sf-total-card">
                                    <h6 class="text-white mb-2">Total Staff Footprint (SF)</h6>
                                    <h3 class="text-white mb-0" id="totalResult">0.00 kg CO2</h3>
                                    <small class="text-white-50">Calculated value for this staff submission</small>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="alert alert-light border border-success">
                                    <h6 class="text-success mb-2">How This Was Calculated</h6>
                                    <div id="calcResults"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-light pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
                    </h5>
                    <p class="text-secondary small">
                        A unified order processing and inventory management platform for modern rental
                        operations - fast, efficient, and sustainable.
                    </p>
                    <p class="text-secondary small mb-0">
                        &copy; @DateTime.Now.Year Pro Rentals. All rights reserved.
                    </p>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="/" class="text-secondary text-decoration-none small">Home</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small">Carbon Dashboard</a></li>
                        <li class="mb-1"><a href="/CarbonFootprint/StaffFootprintView" class="text-secondary text-decoration-none small">Staff Footprint</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Track My Order</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Contact Us</a></li>
                        <li class="mb-1"><a href="/Home/Privacy" class="text-secondary text-decoration-none small">Privacy Policy</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Modules</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-cart3 me-1"></i>Order Processing</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-boxes me-1"></i>Inventory Management</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small"><i class="bi bi-leaf me-1"></i>Carbon Footprint</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-bar-chart me-1"></i>Analytics &amp; Reports</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-shield-lock me-1"></i>Staff Portal</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Contact</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-geo-alt me-2"></i>123 Rental Avenue, Singapore 123456
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-telephone me-2"></i>+65 6123 4567
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-envelope me-2"></i>support@@prorentals.sg
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-clock me-2"></i>Mon - Fri, 9 AM - 6 PM SGT
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="border-secondary mt-3 mb-3" />
            <p class="text-center text-secondary small mb-0">
                Built with Bootstrap 5.3.3 - Pro Rentals Order Processing System v1.0 - 2026
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const EMISSION_RATE_PER_HOUR = 3.53;
        let staffOptions = [];

        const form = document.getElementById('staffFootprintForm');
        const feedbackBanner = document.getElementById('feedbackBanner');
        const resultsSection = document.getElementById('resultsSection');
        const calcResults = document.getElementById('calcResults');
        const totalResult = document.getElementById('totalResult');
        const staffIdSelect = document.getElementById('staffId');

        function clearFieldError(fieldName) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = '';
        }

        function setFieldError(fieldName, message) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = message;
        }

        function setFeedback(message, type) {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'block';
            feedbackBanner.className = type === 'success' ? 'alert alert-success' : 'alert alert-danger';
            feedbackBanner.textContent = message;
        }

        function resetFeedback() {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'none';
            feedbackBanner.textContent = '';
        }

        function sanitiseInput(value) {
            return value.toString().trim();
        }

        function hideCalculationBreakdown() {
            if (resultsSection) resultsSection.style.display = 'none';
            if (calcResults) calcResults.innerHTML = '';
            if (totalResult) totalResult.textContent = '0.00 kg CO2';
        }

        function formatDateTimeForApi(localDateTimeString) {
            const date = new Date(localDateTimeString);
            return date.toISOString();
        }

        function formatDateTimeForDisplay(localDateTimeString) {
            const date = new Date(localDateTimeString);
            return date.toLocaleString();
        }

        async function loadStaffOptions() {
            try {
                const response = await fetch('/api/staff-footprint/staff-options');
                if (!response.ok) {
                    throw new Error('Unable to load staff options');
                }

                staffOptions = await response.json();

                const optionsHtml = ['<option value="">-- Select Staff --</option>'];
                staffOptions.forEach(option => {
                    optionsHtml.push(
                        `<option value="${option.staffId}" data-department="${option.department}" data-weight="${option.departmentWeight}">Staff ${option.staffId} - ${option.department}</option>`
                    );
                });

                staffIdSelect.innerHTML = optionsHtml.join('');
            } catch {
                setFeedback('Unable to load staff list. Please refresh and try again.', 'error');
            }
        }

        function theValidate() {
            let isValid = true;

            const staffIdRaw = sanitiseInput(staffIdSelect.value);
            const checkInRaw = sanitiseInput(document.getElementById('checkInTime').value);
            const checkOutRaw = sanitiseInput(document.getElementById('checkOutTime').value);

            clearFieldError('staffId');
            clearFieldError('checkInTime');
            clearFieldError('checkOutTime');

            const selectedOption = staffIdSelect.options[staffIdSelect.selectedIndex];
            const staffId = parseInt(staffIdRaw, 10);
            const department = selectedOption?.dataset?.department || '';
            const departmentWeight = parseFloat(selectedOption?.dataset?.weight || '0');

            if (!staffIdRaw || isNaN(staffId) || staffId <= 0) {
                setFieldError('staffId', 'Please select a staff member');
                isValid = false;
            }

            if (!checkInRaw) {
                setFieldError('checkInTime', 'Please select a check-in time');
                isValid = false;
            }

            if (!checkOutRaw) {
                setFieldError('checkOutTime', 'Please select a check-out time');
                isValid = false;
            }

            if (checkInRaw && checkOutRaw) {
                const checkInDate = new Date(checkInRaw);
                const checkOutDate = new Date(checkOutRaw);

                if (isNaN(checkInDate.getTime())) {
                    setFieldError('checkInTime', 'Invalid check-in time');
                    isValid = false;
                }

                if (isNaN(checkOutDate.getTime())) {
                    setFieldError('checkOutTime', 'Invalid check-out time');
                    isValid = false;
                }

                if (!isNaN(checkInDate.getTime()) && !isNaN(checkOutDate.getTime()) && checkOutDate <= checkInDate) {
                    setFieldError('checkOutTime', 'Check-out time must be later than check-in time');
                    isValid = false;
                }
            }

            return {
                isValid,
                staffId,
                department,
                departmentWeight,
                checkInTime: checkInRaw,
                checkOutTime: checkOutRaw
            };
        }

        function renderCalculationBreakdown(validation) {
            const checkInDate = new Date(validation.checkInTime);
            const checkOutDate = new Date(validation.checkOutTime);
            const rawHoursWorked = (checkOutDate - checkInDate) / 3600000;
            const hoursWorked = parseFloat(rawHoursWorked.toFixed(2));
            const rawTotal = hoursWorked * EMISSION_RATE_PER_HOUR * validation.departmentWeight;
            const roundedTotal = parseFloat(rawTotal.toFixed(2));

            calcResults.innerHTML = `
                <p class="mb-2"><strong>Staff:</strong> ID ${validation.staffId}</p>
                <p class="mb-2"><strong>Department:</strong> ${validation.department} (Dw = ${validation.departmentWeight.toFixed(2)})</p>
                <p class="mb-2"><strong>Check-In:</strong> ${formatDateTimeForDisplay(validation.checkInTime)}<br /><strong>Check-Out:</strong> ${formatDateTimeForDisplay(validation.checkOutTime)}</p>
                <div class="calc-line"><span class="calc-step-label">Formula</span>SF = H x Er x Dw</div>
                <div class="calc-line"><span class="calc-step-label">Step 1</span>H = (${formatDateTimeForDisplay(validation.checkOutTime)} - ${formatDateTimeForDisplay(validation.checkInTime)}) = ${hoursWorked.toFixed(2)} hours</div>
                <div class="calc-line"><span class="calc-step-label">Step 2</span>SF = ${hoursWorked.toFixed(2)} x ${EMISSION_RATE_PER_HOUR.toFixed(2)} x ${validation.departmentWeight.toFixed(2)} = ${rawTotal.toFixed(4)}</div>
                <div class="calc-line mb-0"><span class="calc-step-label">Final</span>Rounded to 2 d.p. = <strong>${roundedTotal.toFixed(2)} kg CO2</strong></div>
            `;

            totalResult.textContent = `${roundedTotal.toFixed(2)} kg CO2`;
            resultsSection.style.display = 'block';

            return {
                hoursWorked,
                totalStaffCo2: roundedTotal
            };
        }

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            resetFeedback();

            const validation = theValidate();

            if (!validation.isValid) {
                hideCalculationBreakdown();
                setFeedback('Please fix the errors below and resubmit.', 'error');
                return;
            }

            const computed = renderCalculationBreakdown(validation);

            const body = {
                staffId: validation.staffId,
                checkInTime: formatDateTimeForApi(validation.checkInTime),
                checkOutTime: formatDateTimeForApi(validation.checkOutTime),
                hoursWorked: computed.hoursWorked,
                totalStaffCo2: computed.totalStaffCo2
            };

            const btn = document.getElementById('calculateBtn');
            const initialBtnHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Saving...';

            try {
                const response = await fetch('/api/staff-footprint', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(body)
                });

                if (!response.ok) {
                    let err = 'Unable to save staff footprint';
                    try {
                        const data = await response.json();
                        err = data.error || data.message || err;
                    } catch {
                        // Ignore JSON parse errors
                    }
                    throw new Error(err);
                }

                setFeedback(`Staff footprint saved - totalStaffCo2: ${computed.totalStaffCo2.toFixed(2)} kg CO2`, 'success');
                document.querySelectorAll('.text-danger').forEach(el => el.textContent = '');
            } catch (error) {
                setFeedback(error.message || 'An unexpected error occurred.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = initialBtnHtml;
            }
        });

        document.querySelectorAll('#staffId, #checkInTime, #checkOutTime').forEach(input => {
            input.addEventListener('input', () => {
                clearFieldError(input.id);
                resetFeedback();
                hideCalculationBreakdown();
            });
        });

        staffIdSelect.addEventListener('change', () => {
            clearFieldError('staffId');
            resetFeedback();
            hideCalculationBreakdown();
        });

        loadStaffOptions();
    </script>
</body>
</html>
