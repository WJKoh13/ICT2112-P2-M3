@{
    ViewData["Title"] = "Staff Footprint";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staff Footprint - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .carbon-dashboard {
            background:
                radial-gradient(circle at top right, rgba(26, 147, 111, 0.18), transparent 28%),
                linear-gradient(180deg, #f4fbf8 0%, #edf7f2 100%);
            min-height: 100vh;
        }

        .dashboard-hero {
            background: linear-gradient(135deg, #113d2f 0%, #1a936f 55%, #2ec4b6 100%);
            border-radius: 1.5rem;
            overflow: hidden;
            position: relative;
        }

        .dashboard-hero::after {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            content: "";
            height: 18rem;
            position: absolute;
            right: -4rem;
            top: -6rem;
            width: 18rem;
        }

        .chart-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(17, 61, 47, 0.08);
        }

        .chart-shell {
            align-items: center;
            background: linear-gradient(180deg, #f8fcfa 0%, #eef7f2 100%);
            border: 2px dashed #b8d9c9;
            border-radius: 1rem;
            color: #4c6b5c;
            display: flex;
            flex-direction: column;
            font-weight: 600;
            gap: 0.5rem;
            justify-content: center;
            min-height: 240px;
            text-align: center;
        }

        .chart-shell i {
            color: #1a936f;
            font-size: 2rem;
        }

        .chart-shell small {
            max-width: 16rem;
        }

        .chart-shell-hotspot {
            min-height: 320px;
        }

        .form-align-row .form-control,
        .form-align-row .form-select {
            min-height: 44px;
        }

        .calc-line {
            background: #f8fcfa;
            border: 1px solid #d9ece2;
            border-radius: 0.75rem;
            font-family: "Consolas", "Courier New", monospace;
            font-size: 0.95rem;
            margin-bottom: 0.75rem;
            padding: 0.75rem 0.9rem;
        }

        .calc-step-label {
            color: #1a936f;
            font-weight: 700;
            margin-right: 0.5rem;
        }

        .sf-total-card {
            background: linear-gradient(135deg, #0f5f46 0%, #1a936f 100%);
            border: 1px solid #0d6a4d;
        }

        .sf-total-card h6,
        .sf-total-card h3,
        .sf-total-card small {
            color: #ffffff !important;
        }

        .sf-total-card small {
            opacity: 0.92;
        }

        .table-action-controls {
            align-items: flex-end;
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }

        .table-sort-control {
            min-width: 220px;
        }

        .table-sort-control .form-select {
            min-height: 38px;
        }

        @@media (max-width: 576px) {
            .table-sort-control {
                min-width: 100%;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/CarbonMonitoring/CarbonDashboardView">Carbon Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/CarbonFootprint/StaffFootprintView">Staff Footprint</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="#" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-dashboard py-5">
        <div class="container">
            <div class="dashboard-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Staff Footprint Analysis</h1>
                        <p class="lead mb-0 text-white-50">
                            Detailed staff carbon footprint metrics, trendlines, and environmental impact data.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Formula: Staff Footprint Calculation</h2>
                    <p class="text-muted mb-4">
                        <strong>SF = H x Er x Dw</strong><br />
                        <small>Where H = Hours Worked (Check-Out minus Check-In), Er = Emission Rate (3.53 kg CO2/hour), Dw = Department Weight</small>
                    </p>

                    <form id="staffFootprintForm">
                        <div class="row g-3 mb-4 form-align-row">
                            <div class="col-12">
                                <h5 class="text-success mb-3">Staff Information</h5>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="department" class="form-label">Department</label>
                                    <select class="form-select" id="department" required>
                                        <option value="">-- Select Department --</option>
                                    </select>
                                    <div id="departmentError" class="text-danger small mt-1" aria-live="polite"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="staffId" class="form-label">Staff ID</label>
                                    <select class="form-select" id="staffId" required>
                                        <option value="">-- Select Staff --</option>
                                    </select>
                                    <div id="staffIdError" class="text-danger small mt-1" aria-live="polite"></div>
                                </div>
                            </div>

                            <div class="col-12">
                                <h5 class="text-success mb-3">Working Hours</h5>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="checkInTime" class="form-label">Check-In Time</label>
                                    <input type="datetime-local" class="form-control" id="checkInTime" required />
                                    <div id="checkInTimeError" class="text-danger small mt-1" aria-live="polite"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="checkOutTime" class="form-label">Check-Out Time</label>
                                    <input type="datetime-local" class="form-control" id="checkOutTime" required />
                                    <div id="checkOutTimeError" class="text-danger small mt-1" aria-live="polite"></div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col-auto">
                                <button type="submit" id="calculateBtn" class="btn btn-success">
                                    <i class="bi bi-calculator me-2"></i>Calculate & Save Footprint
                                </button>
                            </div>
                            <div class="col-auto">
                                <button type="button" id="cancelEditBtn" class="btn btn-outline-secondary" style="display:none;">
                                    Cancel Edit
                                </button>
                            </div>
                        </div>

                        <div id="feedbackBanner" role="status" class="mb-3" style="display:none"></div>
                    </form>

                    <div id="resultsSection" style="display: none;" class="mt-4 pt-4 border-top">
                        <h4 class="text-success mb-3">Calculation Results</h4>
                        <div class="row">
                            <div class="col-12 mb-3">
                                <div class="alert alert-success sf-total-card">
                                    <h6 class="text-white mb-2">Total Staff Footprint (SF)</h6>
                                    <h3 class="text-white mb-0" id="totalResult">0.00 kg CO2</h3>
                                    <small class="text-white-50">Calculated value for this staff submission</small>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="alert alert-light border border-success">
                                    <h6 class="text-success mb-2">How This Was Calculated</h6>
                                    <div id="calcResults"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-4 border-top">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                            <div>
                                <h4 class="text-success mb-1">Saved Staff Footprints</h4>
                                <p class="text-muted mb-0">Create, update, and delete records on this same page.</p>
                            </div>
                            <div class="table-action-controls">
                                <div class="table-sort-control">
                                    <label for="staffSortBy" class="form-label mb-1 small text-muted">Order by</label>
                                    <select id="staffSortBy" class="form-select form-select-sm">
                                        <option value="id" selected>ID</option>
                                        <option value="staffId">Staff ID</option>
                                        <option value="department">Department (A-Z)</option>
                                        <option value="checkInOldest">Check In (Oldest-Newest)</option>
                                        <option value="checkInNewest">Check In (Newest-Oldest)</option>
                                        <option value="checkOutOldest">Check Out (Oldest-Newest)</option>
                                        <option value="checkOutNewest">Check Out (Newest-Oldest)</option>
                                        <option value="hours">Hours (Low-High)</option>
                                        <option value="totalCo2">Total CO2 (Low-High)</option>
                                    </select>
                                </div>
                                <button type="button" id="refreshStaffListBtn" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                                </button>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead class="table-success">
                                    <tr>
                                        <th>ID</th>
                                        <th>Staff ID</th>
                                        <th>Department</th>
                                        <th>Check-In</th>
                                        <th>Check-Out</th>
                                        <th>Hours</th>
                                        <th>Total CO2</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="staffRecordsBody">
                                    <tr>
                                        <td colspan="8" class="text-center text-muted py-4">Loading records...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-light pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
