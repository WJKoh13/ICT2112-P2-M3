@{
    ViewData["Title"] = "Staff Footprint";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staff Footprint - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .carbon-dashboard {
            background:
                radial-gradient(circle at top right, rgba(26, 147, 111, 0.18), transparent 28%),
                linear-gradient(180deg, #f4fbf8 0%, #edf7f2 100%);
            min-height: 100vh;
        }

        .dashboard-hero {
            background: linear-gradient(135deg, #113d2f 0%, #1a936f 55%, #2ec4b6 100%);
            border-radius: 1.5rem;
            overflow: hidden;
            position: relative;
        }

        .dashboard-hero::after {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            content: "";
            height: 18rem;
            position: absolute;
            right: -4rem;
            top: -6rem;
            width: 18rem;
        }

        .chart-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(17, 61, 47, 0.08);
        }

        .chart-shell {
            align-items: center;
            background: linear-gradient(180deg, #f8fcfa 0%, #eef7f2 100%);
            border: 2px dashed #b8d9c9;
            border-radius: 1rem;
            color: #4c6b5c;
            display: flex;
            flex-direction: column;
            font-weight: 600;
            gap: 0.5rem;
            justify-content: center;
            min-height: 240px;
            text-align: center;
        }

        .chart-shell i {
            color: #1a936f;
            font-size: 2rem;
        }

        .chart-shell small {
            max-width: 16rem;
        }

        .chart-shell-hotspot {
            min-height: 320px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/CarbonMonitoring/CarbonDashboardView">Carbon Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/CarbonFootprint/StaffFootprintView">Staff Footprint</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="#" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-dashboard py-5">
        <div class="container">
            <div class="dashboard-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Staff Footprint Analysis</h1>
                        <p class="lead mb-0 text-white-50">
                            Detailed staff carbon footprint metrics, trendlines, and environmental impact data.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card chart-card mb-4">
                <div class="card-body p-4">
                    <h2 class="h4 mb-1">Formula: Staff Footprint Calculation (Role-Based)</h2>
                    <p class="text-muted mb-4">
                        <strong>SF = Σ(Nj × Wj)</strong><br/>
                        <small>Where SF = Staff Footprint, Nj = number of staff in role j, Wj = weight (importance) of role j</small>
                    </p>

                    <form id="staffFootprintForm">
                        <div class="row g-3 mb-4">
                            <!-- Role Input Instructions -->
                            <div class="col-lg-12">
                                <h5 class="text-success mb-3">Staff Count by Role</h5>
                                <p class="text-muted small mb-3">Add the number of staff for each role. Each role has a different importance weight based on their carbon impact.</p>
                            </div>

                            <!-- Role Selection and Input Container -->
                            <div class="col-lg-12">
                                <div id="roleInputs" class="mb-3">
                                    <!-- Default first role -->
                                    <div class="role-entry card mb-3" data-role="1">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h6 class="mb-0">Role 1</h6>
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRole(1)" style="display: none;">
                                                    <i class="bi bi-trash me-1"></i>Remove
                                                </button>
                                            </div>
                                            <div class="row g-2">
                                                <div class="col-md-6">
                                                    <label class="form-label small">Select Role</label>
                                                    <select class="form-select role-input" data-role="1" data-type="role">
                                                        <option value="">-- Select Role --</option>
                                                        <option value="1.0" data-name="Picker/Packer">Picker/Packer (1.0)</option>
                                                        <option value="1.2" data-name="Forklift Operator">Forklift Operator (1.2)</option>
                                                        <option value="1.4" data-name="Supervisor">Supervisor (1.4)</option>
                                                        <option value="1.6" data-name="Manager">Manager (1.6)</option>
                                                        <option value="1.3" data-name="IT Staff">IT Staff (1.3)</option>
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small">Number of Staff</label>
                                                    <input type="number" class="form-control role-input" data-role="1" data-type="count" placeholder="e.g., 20" step="1" min="0" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <button type="button" id="addRoleBtn" class="btn btn-outline-success btn-sm" onclick="addRole()">
                                    <i class="bi bi-plus-circle me-2"></i>Add Another Role
                                </button>
                            </div>
                        </div>

                        <div class="row g-2 mb-4">
                            <div class="col">
                                <button type="button" id="calculateBtn" class="btn btn-success" onclick="calculateStaffFootprint()">
                                    <i class="bi bi-calculator me-2"></i>Calculate Footprint
                                </button>
                            </div>
                        </div>

                        <!-- Results Section -->
                        <div id="resultsSection" style="display: none;" class="mt-4 pt-4 border-top">
                            <h4 class="text-success mb-3">Calculation Results</h4>
                            <div class="row">
                                <div class="col-lg-6">
                                    <div class="alert alert-light border border-success">
                                        <h6 class="text-success mb-2">Staff Contributions by Role</h6>
                                        <div id="roleResults"></div>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="alert alert-success">
                                        <h6 class="text-white mb-2">Total Staff Footprint (SF)</h6>
                                        <h3 class="text-white mb-0" id="totalResult">0.00</h3>
                                        <small class="text-white-50">Sum of all role contributions</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    <!-- Example Reference -->
                    <div class="mt-4 pt-3 border-top">
                        <h6 class="text-secondary mb-2">Example Warehouse Roles & Weights</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-dark mb-0">
                                <thead>
                                    <tr>
                                        <th>Role</th>
                                        <th>Weight (Wj)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Picker/Packer</td>
                                        <td>1.0</td>
                                    </tr>
                                    <tr>
                                        <td>Forklift Operator</td>
                                        <td>1.2</td>
                                    </tr>
                                    <tr>
                                        <td>Supervisor</td>
                                        <td>1.4</td>
                                    </tr>
                                    <tr>
                                        <td>Manager</td>
                                        <td>1.6</td>
                                    </tr>
                                    <tr>
                                        <td>IT Staff</td>
                                        <td>1.3</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-light pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
                    </h5>
                    <p class="text-secondary small">
                        A unified order processing and inventory management platform for modern rental
                        operations - fast, efficient, and sustainable.
                    </p>
                    <p class="text-secondary small mb-0">
                        &copy; @DateTime.Now.Year Pro Rentals. All rights reserved.
                    </p>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="/" class="text-secondary text-decoration-none small">Home</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small">Carbon Dashboard</a></li>
                        <li class="mb-1"><a href="/CarbonFootprint/StaffFootprintView" class="text-secondary text-decoration-none small">Staff Footprint</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Track My Order</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small">Contact Us</a></li>
                        <li class="mb-1"><a href="/Home/Privacy" class="text-secondary text-decoration-none small">Privacy Policy</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Modules</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-cart3 me-1"></i>Order Processing</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-boxes me-1"></i>Inventory Management</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small"><i class="bi bi-leaf me-1"></i>Carbon Footprint</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-bar-chart me-1"></i>Analytics &amp; Reports</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-shield-lock me-1"></i>Staff Portal</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Contact</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-geo-alt me-2"></i>123 Rental Avenue, Singapore 123456
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-telephone me-2"></i>+65 6123 4567
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-envelope me-2"></i>support@@prorentals.sg
                        </li>
                        <li class="mb-2 text-secondary small">
                            <i class="bi bi-clock me-2"></i>Mon - Fri, 9 AM - 6 PM SGT
                        </li>
                    </ul>
                </div>
            </div>

            <hr class="border-secondary mt-3 mb-3" />
            <p class="text-center text-secondary small mb-0">
                Built with Bootstrap 5.3.3 - Pro Rentals Order Processing System v1.0 - 2026
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let roleCount = 1;

        function addRole() {
            roleCount++;
            const roleHTML = `
                <div class="role-entry card mb-3" data-role="${roleCount}">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h6 class="mb-0">Role ${roleCount}</h6>
                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRole(${roleCount})">
                                <i class="bi bi-trash me-1"></i>Remove
                            </button>
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label small">Select Role</label>
                                <select class="form-select role-input" data-role="${roleCount}" data-type="role">
                                    <option value="">-- Select Role --</option>
                                    <option value="1.0" data-name="Picker/Packer">Picker/Packer (1.0)</option>
                                    <option value="1.2" data-name="Forklift Operator">Forklift Operator (1.2)</option>
                                    <option value="1.4" data-name="Supervisor">Supervisor (1.4)</option>
                                    <option value="1.6" data-name="Manager">Manager (1.6)</option>
                                    <option value="1.3" data-name="IT Staff">IT Staff (1.3)</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small">Number of Staff</label>
                                <input type="number" class="form-control role-input" data-role="${roleCount}" data-type="count" placeholder="e.g., 20" step="1" min="0" />
                            </div>
                        </div>
                    </div>
                </div>
            `;
            document.getElementById('roleInputs').insertAdjacentHTML('beforeend', roleHTML);
        }

        function removeRole(roleNum) {
            const roleElement = document.querySelector(`.role-entry[data-role="${roleNum}"]`);
            if (roleElement) {
                roleElement.remove();
            }
        }

        function calculateStaffFootprint() {
            const resultsSection = document.getElementById('resultsSection');
            const roleResults = document.getElementById('roleResults');
            const totalResult = document.getElementById('totalResult');
            
            let totalSF = 0;
            let resultsHTML = '';

            // Collect all role entries
            document.querySelectorAll('.role-entry').forEach((entry, index) => {
                const roleNum = entry.getAttribute('data-role');
                const roleSelect = entry.querySelector(`[data-role="${roleNum}"][data-type="role"]`);
                const countInput = entry.querySelector(`[data-role="${roleNum}"][data-type="count"]`);

                const weight = parseFloat(roleSelect.value) || 0;
                const count = parseInt(countInput.value) || 0;
                const roleName = roleSelect.options[roleSelect.selectedIndex]?.dataset?.name || 'Unknown Role';

                if (weight > 0 && count > 0) {
                    const roleSF = count * weight;
                    totalSF += roleSF;
                    resultsHTML += `<div class="mb-2">${count} × ${roleName} (${weight}): <strong>${roleSF.toFixed(2)}</strong></div>`;
                }
            });

            if (resultsHTML === '') {
                alert('Please fill in at least one role with valid values.');
                return;
            }

            roleResults.innerHTML = resultsHTML;
            totalResult.textContent = `${totalSF.toFixed(2)}`;
            resultsSection.style.display = 'block';
        }

        // Allow Enter key to calculate
        document.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && e.target.classList.contains('role-input')) {
                calculateStaffFootprint();
            }
        });
    </script>
</body>
</html>
</html>