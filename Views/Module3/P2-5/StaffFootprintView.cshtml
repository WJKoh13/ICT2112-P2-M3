    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script>
        const EMISSION_RATE_PER_HOUR = 3.53;
        let staffOptions = [];
        let editingStaffFootprintId = null;

        const form = document.getElementById('staffFootprintForm');
        const feedbackBanner = document.getElementById('feedbackBanner');
        const resultsSection = document.getElementById('resultsSection');
        const calcResults = document.getElementById('calcResults');
        const totalResult = document.getElementById('totalResult');
        const departmentSelect = document.getElementById('department');
        const staffIdSelect = document.getElementById('staffId');
        const staffRecordsBody = document.getElementById('staffRecordsBody');
        const cancelEditBtn = document.getElementById('cancelEditBtn');
        const refreshStaffListBtn = document.getElementById('refreshStaffListBtn');
        const staffSortBy = document.getElementById('staffSortBy');

        function clearFieldError(fieldName) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = '';
        }

        function setFieldError(fieldName, message) {
            const errorEl = document.getElementById(`${fieldName}Error`);
            if (errorEl) errorEl.textContent = message;
        }

        function setFeedback(message, type) {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'block';
            feedbackBanner.className = type === 'success' ? 'alert alert-success' : 'alert alert-danger';
            feedbackBanner.textContent = message;
        }

        function setInfoFeedback(message) {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'block';
            feedbackBanner.className = 'alert alert-info';
            feedbackBanner.textContent = message;
        }

        function resetFeedback() {
            if (!feedbackBanner) return;
            feedbackBanner.style.display = 'none';
            feedbackBanner.textContent = '';
        }

        function sanitiseInput(value) {
            return value.toString().trim();
        }

        function hideCalculationBreakdown() {
            if (resultsSection) resultsSection.style.display = 'none';
            if (calcResults) calcResults.innerHTML = '';
            if (totalResult) totalResult.textContent = '0.00 kg CO2';
        }

        function formatDateTimeForApi(localDateTimeString) {
            const date = new Date(localDateTimeString);
            return date.toISOString();
        }

        function formatDateTimeForDisplay(localDateTimeString) {
            const date = new Date(localDateTimeString);
            return date.toLocaleString();
        }

        function toLocalInputValue(dateTimeValue) {
            const date = new Date(dateTimeValue);
            if (isNaN(date.getTime())) {
                return '';
            }

            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            const hours = String(date.getHours()).padStart(2, '0');
            const minutes = String(date.getMinutes()).padStart(2, '0');

            return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        function setCreateMode() {
            editingStaffFootprintId = null;
            const btn = document.getElementById('calculateBtn');
            btn.innerHTML = '<i class="bi bi-calculator me-2"></i>Calculate & Save Footprint';
            cancelEditBtn.style.display = 'none';
        }

        function setEditMode(record) {
            editingStaffFootprintId = record.staffCarbonFootprintId;
            const btn = document.getElementById('calculateBtn');
            btn.innerHTML = '<i class="bi bi-pencil-square me-2"></i>Update & Save Footprint';
            cancelEditBtn.style.display = 'inline-block';

            departmentSelect.value = record.department;
            populateStaffOptionsForDepartment(record.department);
            staffIdSelect.value = String(record.staffId);
            document.getElementById('checkInTime').value = toLocalInputValue(record.checkInTime);
            document.getElementById('checkOutTime').value = toLocalInputValue(record.checkOutTime);
            hideCalculationBreakdown();
            setInfoFeedback(`Editing record #${record.staffCarbonFootprintId}. Update values and save.`);
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function loadStaffOptions() {
            try {
                const response = await fetch('/api/staff-footprint/staff-options');
                if (!response.ok) {
                    throw new Error('Unable to load staff options');
                }

                staffOptions = await response.json();
                const departments = [...new Map(
                    staffOptions.map(option => [option.department, option.departmentWeight])
                ).entries()].sort((a, b) => a[0].localeCompare(b[0]));

                const departmentOptionsHtml = ['<option value="">-- Select Department --</option>'];
                departments.forEach(([department, weight]) => {
                    departmentOptionsHtml.push(
                        `<option value="${department}" data-weight="${weight}">${department} (${Number(weight).toFixed(2)})</option>`
                    );
                });

                departmentSelect.innerHTML = departmentOptionsHtml.join('');
                populateStaffOptionsForDepartment('');
            } catch {
                setFeedback('Unable to load staff list. Please refresh and try again.', 'error');
            }
        }

        function populateStaffOptionsForDepartment(department) {
            const filteredStaff = department
                ? staffOptions.filter(option => option.department === department)
                : [];

            const optionsHtml = ['<option value="">-- Select Staff --</option>'];
            filteredStaff.forEach(option => {
                optionsHtml.push(`<option value="${option.staffId}">Staff ${option.staffId}</option>`);
            });

            staffIdSelect.innerHTML = optionsHtml.join('');
        }

        function theValidate() {
            let isValid = true;

            const departmentRaw = sanitiseInput(departmentSelect.value);
            const staffIdRaw = sanitiseInput(staffIdSelect.value);
            const checkInRaw = sanitiseInput(document.getElementById('checkInTime').value);
            const checkOutRaw = sanitiseInput(document.getElementById('checkOutTime').value);

            clearFieldError('department');
            clearFieldError('staffId');
            clearFieldError('checkInTime');
            clearFieldError('checkOutTime');

            const selectedDepartmentOption = departmentSelect.options[departmentSelect.selectedIndex];
            const staffId = parseInt(staffIdRaw, 10);
            const department = departmentRaw;
            const departmentWeight = parseFloat(selectedDepartmentOption?.dataset?.weight || '0');

            if (!department) {
                setFieldError('department', 'Please select a department');
                isValid = false;
            }

            if (!staffIdRaw || isNaN(staffId) || staffId <= 0) {
                setFieldError('staffId', 'Please select a staff member');
                isValid = false;
            }

            if (!checkInRaw) {
                setFieldError('checkInTime', 'Please select a check-in time');
                isValid = false;
            }

            if (!checkOutRaw) {
                setFieldError('checkOutTime', 'Please select a check-out time');
                isValid = false;
            }

            if (checkInRaw && checkOutRaw) {
                const checkInDate = new Date(checkInRaw);
                const checkOutDate = new Date(checkOutRaw);

                if (isNaN(checkInDate.getTime())) {
                    setFieldError('checkInTime', 'Invalid check-in time');
                    isValid = false;
                }

                if (isNaN(checkOutDate.getTime())) {
                    setFieldError('checkOutTime', 'Invalid check-out time');
                    isValid = false;
                }

                if (!isNaN(checkInDate.getTime()) && !isNaN(checkOutDate.getTime()) && checkOutDate <= checkInDate) {
                    setFieldError('checkOutTime', 'Check-out time must be later than check-in time');
                    isValid = false;
                }
            }

            return {
                isValid,
                staffId,
                department,
                departmentWeight,
                checkInTime: checkInRaw,
                checkOutTime: checkOutRaw
            };
        }

        function renderCalculationBreakdown(validation) {
            const checkInDate = new Date(validation.checkInTime);
            const checkOutDate = new Date(validation.checkOutTime);
            const rawHoursWorked = (checkOutDate - checkInDate) / 3600000;
            const hoursWorked = parseFloat(rawHoursWorked.toFixed(2));
            const rawTotal = hoursWorked * EMISSION_RATE_PER_HOUR * validation.departmentWeight;
            const roundedTotal = parseFloat(rawTotal.toFixed(2));

            calcResults.innerHTML = `
                <p class="mb-2"><strong>Staff:</strong> ID ${validation.staffId}</p>
                <p class="mb-2"><strong>Department:</strong> ${validation.department} (Dw = ${validation.departmentWeight.toFixed(2)})</p>
                <p class="mb-2"><strong>Check-In:</strong> ${formatDateTimeForDisplay(validation.checkInTime)}<br /><strong>Check-Out:</strong> ${formatDateTimeForDisplay(validation.checkOutTime)}</p>
                <div class="calc-line"><span class="calc-step-label">Formula</span>SF = H x Er x Dw</div>
                <div class="calc-line"><span class="calc-step-label">Step 1</span>H = (${formatDateTimeForDisplay(validation.checkOutTime)} - ${formatDateTimeForDisplay(validation.checkInTime)}) = ${hoursWorked.toFixed(2)} hours</div>
                <div class="calc-line"><span class="calc-step-label">Step 2</span>SF = ${hoursWorked.toFixed(2)} x ${EMISSION_RATE_PER_HOUR.toFixed(2)} x ${validation.departmentWeight.toFixed(2)} = ${rawTotal.toFixed(4)}</div>
                <div class="calc-line mb-0"><span class="calc-step-label">Final</span>Rounded to 2 d.p. = <strong>${roundedTotal.toFixed(2)} kg CO2</strong></div>
            `;

            totalResult.textContent = `${roundedTotal.toFixed(2)} kg CO2`;
            resultsSection.style.display = 'block';

            return {
                hoursWorked,
                totalStaffCo2: roundedTotal
            };
        }

        function createEmptyRow(message) {
            return `<tr><td colspan="8" class="text-center text-muted py-4">${message}</td></tr>`;
        }

        function sortStaffRecords(records) {
            const selectedSort = staffSortBy?.value || 'id';
            const sorted = [...records];

            sorted.sort((a, b) => {
                if (selectedSort === 'staffId') {
                    return (a.staffId || 0) - (b.staffId || 0);
                }
                if (selectedSort === 'department') {
                    return (a.department || '').localeCompare(b.department || '');
                }
                if (selectedSort === 'checkInOldest') {
                    return new Date(a.checkInTime).getTime() - new Date(b.checkInTime).getTime();
                }
                if (selectedSort === 'checkInNewest') {
                    return new Date(b.checkInTime).getTime() - new Date(a.checkInTime).getTime();
                }
                if (selectedSort === 'checkOutOldest') {
                    return new Date(a.checkOutTime).getTime() - new Date(b.checkOutTime).getTime();
                }
                if (selectedSort === 'checkOutNewest') {
                    return new Date(b.checkOutTime).getTime() - new Date(a.checkOutTime).getTime();
                }
                if (selectedSort === 'hours') {
                    return Number(a.hoursWorked || 0) - Number(b.hoursWorked || 0);
                }
                if (selectedSort === 'totalCo2') {
                    return Number(a.totalStaffCo2 || 0) - Number(b.totalStaffCo2 || 0);
                }

                return (a.staffCarbonFootprintId || 0) - (b.staffCarbonFootprintId || 0);
            });

            return sorted;
        }

        async function loadStaffRecords() {
            try {
                staffRecordsBody.innerHTML = createEmptyRow('Loading records...');
                const response = await fetch('/api/staff-footprint');
                if (!response.ok) {
                    throw new Error('Unable to load staff footprint records');
                }

                const records = await response.json();
                if (!Array.isArray(records) || records.length === 0) {
                    staffRecordsBody.innerHTML = createEmptyRow('No staff footprint records yet.');
                    return;
                }

                const sortedRecords = sortStaffRecords(records);
                staffRecordsBody.innerHTML = sortedRecords.map(record => `
                    <tr>
                        <td>${record.staffCarbonFootprintId}</td>
                        <td>${record.staffId}</td>
                        <td>${record.department ?? ''}</td>
                        <td>${formatDateTimeForDisplay(record.checkInTime)}</td>
                        <td>${formatDateTimeForDisplay(record.checkOutTime)}</td>
                        <td>${Number(record.hoursWorked).toFixed(2)}</td>
                        <td>${Number(record.totalStaffCo2).toFixed(2)} kg CO2</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-outline-primary btn-sm me-1 edit-staff-btn"
                                data-id="${record.staffCarbonFootprintId}"
                                data-staff-id="${record.staffId}"
                                data-department="${record.department ?? ''}"
                                data-check-in="${record.checkInTime}"
                                data-check-out="${record.checkOutTime}">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <button type="button" class="btn btn-outline-danger btn-sm delete-staff-btn"
                                data-id="${record.staffCarbonFootprintId}">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                staffRecordsBody.innerHTML = createEmptyRow(error.message || 'Unable to load records.');
            }
        }

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            resetFeedback();

            const validation = theValidate();

            if (!validation.isValid) {
                hideCalculationBreakdown();
                setFeedback('Please fix the errors below and resubmit.', 'error');
                return;
            }

            const computed = renderCalculationBreakdown(validation);

            const body = {
                staffId: validation.staffId,
                checkInTime: formatDateTimeForApi(validation.checkInTime),
                checkOutTime: formatDateTimeForApi(validation.checkOutTime),
                hoursWorked: computed.hoursWorked,
                totalStaffCo2: computed.totalStaffCo2
            };

            const btn = document.getElementById('calculateBtn');
            const initialBtnHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Saving...';

            try {
                const isEditing = editingStaffFootprintId !== null;
                const endpoint = isEditing
                    ? `/api/staff-footprint/${editingStaffFootprintId}`
                    : '/api/staff-footprint';

                const response = await fetch(endpoint, {
                    method: isEditing ? 'PUT' : 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(body)
                });

                if (!response.ok) {
                    let err = 'Unable to save staff footprint';
                    try {
                        const data = await response.json();
                        err = data.error || data.message || err;
                    } catch {
                        // ignore JSON parse errors
                    }
                    throw new Error(err);
                }

                setFeedback(
                    isEditing
                        ? `Staff footprint updated - totalStaffCo2: ${computed.totalStaffCo2.toFixed(2)} kg CO2`
                        : `Staff footprint saved - totalStaffCo2: ${computed.totalStaffCo2.toFixed(2)} kg CO2`,
                    'success');
                document.querySelectorAll('.text-danger').forEach(el => el.textContent = '');
                form.reset();
                populateStaffOptionsForDepartment('');
                setCreateMode();
                await loadStaffRecords();
            } catch (error) {
                setFeedback(error.message || 'An unexpected error occurred.', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = initialBtnHtml;
            }
        });

        document.querySelectorAll('#staffId, #checkInTime, #checkOutTime').forEach(input => {
            input.addEventListener('input', () => {
                clearFieldError(input.id);
                resetFeedback();
                hideCalculationBreakdown();
            });
        });

        departmentSelect.addEventListener('change', () => {
            const selectedDepartment = departmentSelect.value;
            populateStaffOptionsForDepartment(selectedDepartment);
            clearFieldError('department');
            clearFieldError('staffId');
            resetFeedback();
            hideCalculationBreakdown();
        });

        staffIdSelect.addEventListener('change', () => {
            clearFieldError('staffId');
            resetFeedback();
            hideCalculationBreakdown();
        });

        cancelEditBtn.addEventListener('click', () => {
            form.reset();
            populateStaffOptionsForDepartment('');
            setCreateMode();
            resetFeedback();
            hideCalculationBreakdown();
            document.querySelectorAll('.text-danger').forEach(el => el.textContent = '');
        });

        refreshStaffListBtn.addEventListener('click', () => {
            loadStaffRecords();
        });

        staffSortBy.addEventListener('change', () => {
            loadStaffRecords();
        });

        staffRecordsBody.addEventListener('click', async (event) => {
            const editBtn = event.target.closest('.edit-staff-btn');
            const deleteBtn = event.target.closest('.delete-staff-btn');

            if (editBtn) {
                setEditMode({
                    staffCarbonFootprintId: parseInt(editBtn.dataset.id, 10),
                    staffId: parseInt(editBtn.dataset.staffId, 10),
                    department: editBtn.dataset.department,
                    checkInTime: editBtn.dataset.checkIn,
                    checkOutTime: editBtn.dataset.checkOut
                });
                return;
            }

            if (!deleteBtn) {
                return;
            }

            const id = parseInt(deleteBtn.dataset.id, 10);
            if (!confirm(`Delete staff footprint record #${id}?`)) {
                return;
            }

            try {
                const response = await fetch(`/api/staff-footprint/${id}`, {
                    method: 'DELETE'
                });

                if (!response.ok) {
                    let err = 'Unable to delete record';
                    try {
                        const data = await response.json();
                        err = data.error || data.message || err;
                    } catch {
                        // ignore JSON parse errors
                    }
                    throw new Error(err);
                }

                if (editingStaffFootprintId === id) {
                    form.reset();
                    populateStaffOptionsForDepartment('');
                    setCreateMode();
                    hideCalculationBreakdown();
                }

                setFeedback(`Deleted staff footprint record #${id}.`, 'success');
                await loadStaffRecords();
            } catch (error) {
                setFeedback(error.message || 'An unexpected error occurred.', 'error');
            }
        });

        async function initializePage() {
            setCreateMode();
            await loadStaffOptions();
            await loadStaffRecords();
        }

        initializePage();
    </script>
</body>
</html>
