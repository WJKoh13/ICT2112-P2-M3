@model ProRental.Domain.Module3.P2_5.Entities.ProductFootprintCalculationViewModel

@{
    ViewData["Title"] = "Product Carbon Footprint Calculator";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Product Carbon Footprint Calculator - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .carbon-page {
            background:
                radial-gradient(circle at top right, rgba(26, 147, 111, 0.18), transparent 28%),
                linear-gradient(180deg, #f4fbf8 0%, #edf7f2 100%);
            min-height: 100vh;
        }

        .page-hero {
            background: linear-gradient(135deg, #113d2f 0%, #1a936f 55%, #2ec4b6 100%);
            border-radius: 1.5rem;
            overflow: hidden;
            position: relative;
        }

        .page-hero::after {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 999px;
            content: "";
            height: 18rem;
            position: absolute;
            right: -4rem;
            top: -6rem;
            width: 18rem;
        }

        .feature-card {
            border: 0;
            border-radius: 1.25rem;
            box-shadow: 0 1rem 2.5rem rgba(17, 61, 47, 0.08);
        }

        .formula-chip {
            background: #eff8f3;
            border: 1px solid #d8ebe0;
            border-radius: 1rem;
        }
    </style>
</head>
<body>
    @* ================================================================
       NAVBAR
       Same homepage navbar shell.
       ================================================================ *@
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-cart3 me-1"></i>Order Processing
                        </a>
                        <ul class="dropdown-menu">
                            <li><h6 class="dropdown-header text-uppercase" style="color: #2d7a4f; font-size: 0.7rem;">Module 1</h6></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-plus-circle me-2" style="color: #2d7a4f;"></i>Place Order</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-search me-2" style="color: #2d7a4f;"></i>Track Order</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-truck me-2" style="color: #2d7a4f;"></i>Manage Dispatch</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-arrow-return-left me-2" style="color: #2d7a4f;"></i>Handle Returns</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-cash-coin me-2" style="color: #2d7a4f;"></i>Deposit Refunds</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-bell me-2" style="color: #2d7a4f;"></i>Order Notifications</a></li>
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-boxes me-1"></i>Inventory Management
                        </a>
                        <ul class="dropdown-menu">
                            <li><h6 class="dropdown-header text-uppercase" style="color: #0d6efd; font-size: 0.7rem;">Module 2</h6></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-grid me-2" style="color: #0d6efd;"></i>Product Catalogue</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-box-seam me-2" style="color: #0d6efd;"></i>Stock Management</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-arrow-repeat me-2" style="color: #0d6efd;"></i>Return Processing Pipeline</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-building-check me-2" style="color: #0d6efd;"></i>Trusted Supplier Registry</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-bar-chart-line me-2" style="color: #0d6efd;"></i>Analytics &amp; Reports</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-tag me-2" style="color: #0d6efd;"></i>Product Clearance</a></li>
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-leaf me-1"></i>Carbon Footprint
                        </a>
                        <ul class="dropdown-menu">
                            <li><h6 class="dropdown-header text-uppercase" style="color: #0a9396; font-size: 0.7rem;">Module 3</h6></li>
                            <li><a class="dropdown-item" href="/ProductFootprint"><i class="bi bi-calculator me-2" style="color: #0a9396;"></i>Product Carbon Calculator</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-truck-flatbed me-2" style="color: #0a9396;"></i>Shipment Carbon Tracker</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-signpost-2 me-2" style="color: #0a9396;"></i>Route Distance Determination</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-building me-2" style="color: #0a9396;"></i>Warehouse Storage Emissions</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-recycle me-2" style="color: #0a9396;"></i>Return Process Carbon Lifecycle</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-collection me-2" style="color: #0a9396;"></i>Batch Delivery Consolidation</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                    <a href="#" class="btn btn-primary btn-sm">
                        <i class="bi bi-person-plus me-1"></i>Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="carbon-page py-5">
        <div class="container">
            <div class="page-hero text-white p-4 p-lg-5 mb-4">
                <div class="row align-items-center gy-4 position-relative">
                    <div class="col-lg-8">
                        <span class="badge rounded-pill text-bg-light text-success fw-semibold mb-3">Module 3 P2-5</span>
                        <h1 class="display-6 fw-bold mb-3">Product Carbon Footprint Calculator</h1>
                        <p class="lead mb-0 text-white-50">
                            Select a product by SKU, enter the product mass and toxic percentage, then calculate and save the resulting footprint.
                        </p>
                    </div>
                </div>
            </div>

            <div class="card feature-card">
                <div class="card-body p-4 p-lg-5">
                    <div class="formula-chip p-3 mb-4">
                        <div class="fw-semibold text-success mb-1">Formula</div>
                        <div class="mb-0"><code>Carbon Footprint = Product Mass x 0.5 x (1 + Toxic Percentage / 100)</code></div>
                    </div>

                    <form asp-action="Index" asp-controller="ProductFootprint" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                        <div class="row g-4">
                            <div class="col-12">
                                <label asp-for="ProductId" class="form-label fw-semibold"></label>
                                <select asp-for="ProductId" asp-items="Model.ProductOptions" class="form-select form-select-lg">
                                    <option value="">Select a product</option>
                                </select>
                                <span asp-validation-for="ProductId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ProductMass" class="form-label fw-semibold">Product Mass (g)</label>
                                <input asp-for="ProductMass" class="form-control form-control-lg" type="number" min="0" step="0.01" />
                                <span asp-validation-for="ProductMass" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ToxicPercentage" class="form-label fw-semibold"></label>
                                <input asp-for="ToxicPercentage" class="form-control form-control-lg" type="number" min="0" max="100" step="0.01" />
                                <span asp-validation-for="ToxicPercentage" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-3 mt-4">
                            <button type="submit" class="btn btn-success btn-lg px-4">Calculate and Save</button>
                            <a href="/CarbonMonitoring/CarbonDashboardView" class="btn btn-outline-primary btn-lg px-4">View Carbon Dashboard</a>
                        </div>
                    </form>

                    @if (Model.CarbonFootprint.HasValue)
                    {
                        var selectedProductName = Model.ProductOptions?.FirstOrDefault(item => item.Value == Model.ProductId?.ToString())?.Text ?? "Unknown product";
                        var isEcoFriendly = Model.CarbonFootprint.Value < 250;

                        <div class="alert alert-success mt-4 mb-0">
                            <div class="fw-semibold mb-1">Calculation saved successfully.</div>
                            <div>Product Name: <strong>@selectedProductName</strong></div>
                            <div>Calculated product carbon footprint: <strong>@Model.CarbonFootprint.Value.ToString("0.00") g CO2e</strong></div>

                            @if (isEcoFriendly)
                            {
                                <div class="text-success mt-2">
                                    <i class="bi bi-check-circle-fill me-1"></i> This product is eco friendly
                                </div>
                            }
                            else
                            {
                                <div class="text-danger mt-2">
                                    <i class="bi bi-x-circle-fill me-1"></i> This product is not eco friendly
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-light pt-5 pb-4">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-box-seam-fill fs-4 me-2" style="color: #2d7a4f;"></i>
                        <span class="fw-bold fs-5">Pro Rentals</span>
                    </div>
                    <p class="text-secondary small mb-3">
                        Smart rental operations with integrated sustainability tracking for products, people, and facilities.
                    </p>
                    <p class="text-secondary small mb-0">
                        &copy; @DateTime.Now.Year Pro Rentals. All rights reserved.
                    </p>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="/" class="text-secondary text-decoration-none small">Home</a></li>
                        <li class="mb-1"><a href="/ProductFootprint" class="text-secondary text-decoration-none small">Product Footprint</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small">Carbon Dashboard</a></li>
                        <li class="mb-1"><a href="/Home/Privacy" class="text-secondary text-decoration-none small">Privacy Policy</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Modules</h6>
                    <ul class="list-unstyled">
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-cart3 me-1"></i>Order Processing</a></li>
                        <li class="mb-1"><a href="#" class="text-secondary text-decoration-none small"><i class="bi bi-boxes me-1"></i>Inventory Management</a></li>
                        <li class="mb-1"><a href="/CarbonMonitoring/CarbonDashboardView" class="text-secondary text-decoration-none small"><i class="bi bi-leaf me-1"></i>Carbon Footprint</a></li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3" style="letter-spacing: 0.05em;">Contact</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 text-secondary small"><i class="bi bi-geo-alt me-2"></i>123 Rental Avenue, Singapore 123456</li>
                        <li class="mb-2 text-secondary small"><i class="bi bi-telephone me-2"></i>+65 6123 4567</li>
                        <li class="mb-2 text-secondary small"><i class="bi bi-envelope me-2"></i>support@@prorentals.sg</li>
                        <li class="mb-2 text-secondary small"><i class="bi bi-clock me-2"></i>Mon - Fri, 9 AM - 6 PM SGT</li>
                    </ul>
                </div>
            </div>

            <hr class="border-secondary mt-3 mb-3" />
            <p class="text-center text-secondary small mb-0">
                Built with Bootstrap 5.3.3 - Pro Rentals Order Processing System v1.0 - 2026
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
