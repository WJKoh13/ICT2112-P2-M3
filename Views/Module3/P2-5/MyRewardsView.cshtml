@using ProRental.Domain.Entities
@model List<Customerreward>
@{
    ViewData["Title"] = "My Eco Rewards";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Eco Rewards - Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { margin-bottom: 0; }

        .eco-page {
            background: linear-gradient(180deg, #f4f8f6 0%, #ffffff 100%);
            min-height: 100vh;
        }

        .catalog-card, .metric-card {
            border: 0;
            border-radius: 1rem;
            box-shadow: 0 1rem 2rem rgba(15, 45, 30, 0.08);
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/catalog/eco">Feature 5 Eco Catalog</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/RewardsDashboard/MyRewards">My Eco Rewards</a>
                    </li>
                </ul>
                <div class="d-flex gap-2">
                    <a href="#" class="btn btn-outline-light btn-sm"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>
                    <a href="#" class="btn btn-primary btn-sm"><i class="bi bi-person-plus me-1"></i>Register</a>
                </div>
            </div>
        </div>
    </nav>

    <section class="eco-page">
        <div class="container py-5" style="max-width: 800px;">

            <div class="text-center mb-5">
                <i class="bi bi-gift fs-1 text-success"></i>
                <h2 class="fw-bold mt-2">My Eco Rewards</h2>
                <p class="text-muted">Vouchers earned from your eco-friendly orders</p>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card metric-card text-center">
                        <div class="card-body">
                            <div class="fs-2 fw-bold text-success">@Model.Count</div>
                            <div class="text-muted small">Rewards Earned</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card metric-card text-center">
                        <div class="card-body">
                            <div class="fs-2 fw-bold text-success">
                                $@Model.Sum(r => r.GetRewardvalue()).ToString("F0")
                            </div>
                            <div class="text-muted small">Total Voucher Value</div>
                        </div>
                    </div>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="card catalog-card text-center py-5">
                    <div class="card-body">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <p class="mt-3 text-muted">No rewards issued yet. Place eco-friendly orders to earn vouchers!</p>
                        <a href="/" class="btn btn-success mt-2">Browse Orders</a>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var r in Model)
                    {
                        <div class="col-12">
                            <div class="card catalog-card">
                                <div class="card-body d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-success bg-opacity-10 p-3">
                                            <i class="bi bi-ticket-perforated fs-4 text-success"></i>
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@r.GetRewardtype() Voucher</div>
                                            <div class="text-muted small">
                                                Issued @r.GetCreatedat().ToString("dd MMM yyyy")
                                            </div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="fs-4 fw-bold text-success">
                                            $@r.GetRewardvalue().ToString("F0")
                                        </div>
                                        <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="text-center mt-4">
                <a href="/" class="btn btn-outline-success">
                    <i class="bi bi-arrow-left me-2"></i>Back to Home
                </a>
            </div>

        </div>
    </section>

    <footer class="bg-dark text-light pt-5 pb-3">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
                    </h5>
                    <p class="text-secondary small mb-0">
                        Eco-product discovery with carbon-aware browse, search, sorting, and budget filtering.
                    </p>
                </div>
                <div class="col-lg-4">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3">Quick Links</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-1"><a href="/" class="text-secondary text-decoration-none small">Home</a></li>
                        <li class="mb-1"><a href="/catalog/eco" class="text-secondary text-decoration-none small">Feature 5 Eco Catalog</a></li>
                        <li class="mb-1"><a href="/RewardsDashboard/MyRewards" class="text-secondary text-decoration-none small">My Eco Rewards</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="text-uppercase text-secondary fw-semibold small mb-3">Status</h6>
                    <p class="text-secondary small mb-0">@Model.Count reward(s) loaded.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>