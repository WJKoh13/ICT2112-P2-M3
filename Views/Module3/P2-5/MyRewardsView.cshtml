@using ProRental.Domain.Entities
@model List<Customerreward>
@{
    ViewData["Title"] = "My Eco Rewards";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Eco Rewards — Pro Rentals</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-box-seam-fill me-2" style="color: #2d7a4f;"></i>Pro Rentals
            </a>
            <div class="d-flex gap-2">
                <a href="/" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-house me-1"></i>Home
                </a>
            </div>
        </div>
    </nav>

    <div class="container py-5" style="max-width: 800px;">

        <div class="text-center mb-5">
            <i class="bi bi-gift fs-1 text-success"></i>
            <h2 class="fw-bold mt-2">My Eco Rewards</h2>
            <p class="text-muted">Vouchers earned from your eco-friendly orders</p>
        </div>

        @* ── Summary cards ──────────────────────────────────────────────────── *@
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card border-0 bg-white shadow-sm text-center">
                    <div class="card-body">
                        <div class="fs-2 fw-bold text-success">@Model.Count</div>
                        <div class="text-muted small">Rewards Earned</div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 bg-white shadow-sm text-center">
                    <div class="card-body">
                        <div class="fs-2 fw-bold text-success">
                            $@Model.Sum(r => r.GetRewardvalue()).ToString("F0")
                        </div>
                        <div class="text-muted small">Total Voucher Value</div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Rewards list ───────────────────────────────────────────────────── *@
        @if (!Model.Any())
        {
            <div class="card border-0 shadow-sm text-center py-5">
                <div class="card-body">
                    <i class="bi bi-inbox fs-1 text-muted"></i>
                    <p class="mt-3 text-muted">No rewards issued yet. Place eco-friendly orders to earn vouchers!</p>
                    <a href="/" class="btn btn-success mt-2">Browse Orders</a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var r in Model)
                {
                    <div class="col-12">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                                        <i class="bi bi-ticket-perforated fs-4 text-success"></i>
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@r.GetRewardtype() Voucher</div>
                                        <div class="text-muted small">
                                            Issued @r.GetCreatedat().ToString("dd MMM yyyy")
                                        </div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="fs-4 fw-bold text-success">
                                        $@r.GetRewardvalue().ToString("F0")
                                    </div>
                                    <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="text-center mt-4">
            <a href="/" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Home
            </a>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>