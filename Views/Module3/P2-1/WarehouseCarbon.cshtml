@using ProRental.Domain.Entities
@using ProRental.Interfaces.Module2.P2_3
@using ProRental.Interfaces.Module3.P2_1
@{
    ViewData["Title"] = "Warehouse Carbon Emissions";

    var warehouse = ViewData["Hub"] as Warehouse;
    var hours = ViewData["Hours"] is double hourValue ? hourValue : 0;
    var carbon = ViewData["CarbonEmission"] is double carbonValue ? carbonValue : 0;
    var storedProducts = ViewData["StoredProducts"] as List<ProductStorageInfo> ?? new List<ProductStorageInfo>();
}

<h2 class="mb-4"><i class="bi bi-building"></i> Warehouse Storage Emissions</h2>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link active" asp-controller="Warehouse" asp-action="GetWarehouseCarbon">
            <i class="bi bi-building"></i> Warehouse Carbon
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Warehouse" asp-action="GetProductCarbonEmission" asp-route-productId="1">
            <i class="bi bi-box-seam"></i> Product Carbon
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Warehouse" asp-action="GetRecommendedClearing">
            <i class="bi bi-arrow-down-circle"></i> Recommended Clearing
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Warehouse" asp-action="GetProductTimeInWarehouse">
            <i class="bi bi-clock-history"></i> Product Time
        </a>
    </li>
</ul>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-controller="Warehouse" asp-action="GetWarehouseCarbon" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label fw-bold">Hours to Calculate</label>
                <input type="number" name="hours" class="form-control" value="@hours" min="0.1" step="0.1" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-calculator"></i> Calculate
                </button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header">
                Emission Summary
            </div>
            <div class="card-body">
                <table class="table table-bordered align-middle mb-0">
                    <tr>
                        <th>Warehouse</th>
                        <td>@(warehouse?.GetAddress() ?? "Unknown")</td>
                    </tr>
                    <tr>
                        <th>Warehouse Code</th>
                        <td>@(warehouse?.GetWarehouseCode() ?? "N/A")</td>
                    </tr>
                    <tr>
                        <th>Measured Duration</th>
                        <td>@(string.Format("{0:F1}", hours)) hours</td>
                    </tr>
                    <tr>
                        <th>Total CO2 Emissions</th>
                        <td>
                            <span class="badge bg-success fs-6">@(string.Format("{0:F4}", carbon)) kg CO2</span>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header">
                Warehouse Details
            </div>
            <div class="card-body">
                @if (warehouse == null)
                {
                    <div class="alert alert-warning mb-0">
                        Warehouse information could not be loaded for this hub.
                    </div>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <tr>
                            <th>Status</th>
                            <td>@(warehouse.GetOperationalStatus() ?? "Unknown")</td>
                        </tr>
                        <tr>
                            <th>Operation Time</th>
                            <td>@(warehouse.GetOperationTime() ?? "N/A")</td>
                        </tr>
                        <tr>
                            <th>Country</th>
                            <td>@warehouse.GetCountryCode()</td>
                        </tr>
                        <tr>
                            <th>Address</th>
                            <td>@warehouse.GetAddress()</td>
                        </tr>
                        <tr>
                            <th>Capacity</th>
                            <td>@(warehouse.GetMaxProductCapacity()?.ToString() ?? "N/A")</td>
                        </tr>
                        <tr>
                            <th>Total Volume</th>
                            <td>@(warehouse.GetTotalWarehouseVolume()?.ToString("F2") ?? "N/A")</td>
                        </tr>
                        <tr>
                            <th>Emissions Per Hour</th>
                            <td>@(string.Format("{0:F4}", ViewData["EmissionsPerHour"])) kg CO2</td>
                        </tr>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-box-seam"></i> Products Currently Stored
    </div>
    <div class="card-body">
        @if (storedProducts.Count == 0)
        {
            <div class="alert alert-secondary mb-0">
                No inventory data available.
            </div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Serial Number</th>
                        <th>Stored Since</th>
                        <th>Hours Stored</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < storedProducts.Count; i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>
                                <a asp-controller="Warehouse" asp-action="GetProductCarbonEmission" asp-route-productId="@storedProducts[i].ProductId">
                                    @storedProducts[i].ProductName
                                </a>
                                <span class="text-muted">(#@storedProducts[i].ProductId)</span>
                            </td>
                            <td><code>@storedProducts[i].SerialNumber</code></td>
                            <td>@storedProducts[i].StoredSince.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="badge @(storedProducts[i].HoursStored > 13140 ? "bg-danger" : storedProducts[i].HoursStored > 720 ? "bg-warning text-dark" : "bg-success")">
                                    @(string.Format("{0:F1}", storedProducts[i].HoursStored)) hrs
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
