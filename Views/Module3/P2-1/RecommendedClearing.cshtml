@using ProRental.Domain.Entities
@using ProRental.Interfaces.Module3.P2_1
@{
    ViewData["Title"] = "Recommended Items to Clear";
    var items = ViewData["Items"] as List<ItemCarbonInfo> ?? new List<ItemCarbonInfo>();
    var hub = ViewData["Hub"] as TransportationHub;
}

<h2 class="mb-4"><i class="bi bi-arrow-down-circle"></i> Recommended Items to Clear</h2>

<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link" asp-controller="Warehouse" asp-action="GetWarehouseCarbon">
            <i class="bi bi-building"></i> Warehouse Carbon
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Warehouse" asp-action="GetProductCarbonEmission" asp-route-productId="1">
            <i class="bi bi-box-seam"></i> Product Carbon
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link active" asp-controller="Warehouse" asp-action="GetRecommendedClearing">
            <i class="bi bi-arrow-down-circle"></i> Recommended Clearing
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Warehouse" asp-action="GetProductTimeInWarehouse">
            <i class="bi bi-clock-history"></i> Product Time
        </a>
    </li>
</ul>

<div class="card mb-4">
    <div class="card-header">
        @(hub?.GetAddress() ?? "Warehouse") — Top 15 items stored 18+ months, ranked by carbon impact
    </div>
    <div class="card-body">
        @if (items.Count == 0)
        {
            <div class="alert alert-secondary">
                <i class="bi bi-check-circle"></i> No items have been stored for 18 months or longer in this warehouse.
            </div>
        }
        else
        {
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Product</th>
                        <th>Serial Number</th>
                        <th>Months Stored</th>
                        <th>Total CO2 (kg)</th>
                        <th>Emission Rate (kg/hr)</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < items.Count; i++)
                    {
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@items[i].ProductName <span class="text-muted">(#@items[i].ProductId)</span></td>
                            <td><code>@items[i].SerialNumber</code></td>
                            <td>@(string.Format("{0:F1}", items[i].HoursStored / 720)) months</td>
                            <td>
                                <span class="badge @(items[i].CarbonEmission > 5 ? "bg-danger" : items[i].CarbonEmission > 2 ? "bg-warning text-dark" : "bg-success")">
                                    @(string.Format("{0:F4}", items[i].CarbonEmission)) kg
                                </span>
                            </td>
                            <td>
                                <span class="text-muted">@(string.Format("{0:F6}", items[i].EmissionRatePerHour)) kg/hr</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <p class="text-muted"><small>Items with the highest carbon emissions should be cleared first to reduce warehouse footprint.</small></p>
        }
    </div>
</div>
