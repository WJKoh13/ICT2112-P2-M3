@model List<ProRental.Domain.Entities.DeliveryBatch>

@{
    ViewData["Title"] = "BatchDeliveryView";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">BatchDeliveryView</h2>
        <p class="text-muted mb-0">Available delivery batches and first-leg carbon savings.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/">Home</a>
        <a class="btn btn-outline-primary" href="/module3/p2-1/order-simulation">Order Simulation</a>
        <a class="btn btn-primary" href="/module3/p2-1/batch-delivery/refresh">Refresh</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Batch ID</th>
                <th>Hub ID</th>
                <th>Destination Address</th>
                <th>Status</th>
                <th>Total Orders</th>
                <th>Batch Weight (kg)</th>
                <th>Carbon Savings (kg)</th>
                <th>Order IDs</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-center text-muted">No batches available.</td>
                </tr>
            }
            else
            {
                @foreach (var batch in Model)
                {
                    <tr>
                        <td>@batch.ReadDeliveryBatchIdentifier()</td>
                        <td>@batch.ReadSourceHub()</td>
                        <td>@batch.ReadDestinationAddress()</td>
                        <td>@batch.ReadDeliveryBatchStatus()</td>
                        <td>@batch.ReadTotalOrders()</td>
                        <td>@batch.ReadBatchWeightKg().ToString("0.##")</td>
                        <td>@batch.ReadCarbonSavings().ToString("0.###")</td>
                        <td>@string.Join(", ", batch.ReadListOfOrders())</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
