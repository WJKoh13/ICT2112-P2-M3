@model IReadOnlyList<ProRental.Models.Module3.P2_1.ShippingPreferenceCard>
@* Feature 1 landing page: shows the three preference cards only. Real routing, carbon,
   and persistence do not happen until the customer confirms one preference. *@
@* by: ernest *@
@{
    ViewData["Title"] = "Shipping Options";
    var orderId = Model.FirstOrDefault()?.OrderId ?? 0;
}

<section class="py-4">
    <div class="mb-4">
        <div>
            <p class="text-uppercase text-muted small mb-1">Checkout</p>
            <h1 class="h3 mb-1">Choose a shipping preference</h1>
            <p class="text-muted mb-0">Select one preference first. Route generation and carbon pricing will only happen after you confirm it.</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            No shipping options are available for this order yet.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var option in Model)
            {
                <div class="col-12 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <div class="mb-3">
                                <h2 class="h5 mb-1">@option.DisplayName</h2>
                                <span class="badge text-bg-light">@option.PreferenceType</span>
                            </div>

                            <p class="text-muted small flex-grow-1">@option.Description</p>

                            <dl class="row small mb-4">
                                <dt class="col-6 text-muted">Allowed modes</dt>
                                <dd class="col-6 text-end mb-0">@option.AllowedModesLabel</dd>
                            </dl>

                            <form asp-action="SelectShippingPreference" method="post" class="mt-auto">
                                <input type="hidden" name="orderId" value="@option.OrderId" />
                                <input type="hidden" name="preferenceType" value="@option.PreferenceType" />
                                <button type="submit" class="btn btn-primary w-100">Confirm preference</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>
