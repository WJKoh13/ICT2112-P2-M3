@model List<ProRental.Domain.Module3.P2_1.Models.SimulatedOrder>

@{
    var pendingBatches = ViewBag.PendingBatches as List<ProRental.Domain.Entities.DeliveryBatch>
        ?? new List<ProRental.Domain.Entities.DeliveryBatch>();
}

@{
    ViewData["Title"] = "Batch Simulation";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Order Simulation & Batch Dispatch</h2>
        <p class="text-muted mb-0">Create demo orders, auto-consolidate selected orders, and mark pending batches shipped.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" href="/">Home</a>
        <a class="btn btn-outline-primary" href="/module3/p2-1/batch-delivery/view">Go to BatchDeliveryView</a>
    </div>
</div>

@if (TempData["BatchSimulationMessage"] is string success)
{
    <div class="alert alert-success">@success</div>
}

@if (TempData["BatchSimulationError"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header fw-semibold">Create Order</div>
            <div class="card-body">
                <form method="post" action="/module3/p2-1/order-simulation/create-order">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" for="DestinationAddress">Destination Address</label>
                        <input class="form-control" id="DestinationAddress" name="DestinationAddress" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="Quantity">Quantity</label>
                        <input class="form-control" id="Quantity" name="Quantity" type="number" min="1" value="1" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="WeightKg">Weight (kg)</label>
                        <input class="form-control" id="WeightKg" name="WeightKg" type="number" min="0.1" step="0.1" value="1" required />
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" id="UseBatchShipping" name="UseBatchShipping" type="checkbox" value="true" checked />
                        <input type="hidden" name="UseBatchShipping" value="false" />
                        <label class="form-check-label" for="UseBatchShipping">Use batch shipping to save carbon footprint</label>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Create Order</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header fw-semibold">Existing Orders</div>
            <div class="table-responsive">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Address</th>
                            <th>Qty</th>
                            <th>Weight (kg)</th>
                            <th>Batch Shipping</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No orders yet.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td>@order.OrderId</td>
                                    <td>@order.DestinationAddress</td>
                                    <td>@order.Quantity</td>
                                    <td>@order.WeightKg.ToString("0.##")</td>
                                    <td>@(order.UseBatchShipping ? "Yes" : "No")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header fw-semibold">Mark Pending Batches as Shipped</div>
            <div class="card-body">
                <form method="post" action="/module3/p2-1/order-simulation/mark-shipped">
                    @Html.AntiForgeryToken()
                    @if (pendingBatches.Count == 0)
                    {
                        <p class="text-muted mb-0">No pending batches available.</p>
                    }
                    else
                    {
                        @foreach (var batch in pendingBatches)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="batchIds" value="@batch.ReadDeliveryBatchIdentifier()" id="batch-@batch.ReadDeliveryBatchIdentifier()" />
                                <label class="form-check-label" for="batch-@batch.ReadDeliveryBatchIdentifier()">
                                    Batch #@batch.ReadDeliveryBatchIdentifier() — Hub @batch.ReadSourceHub() — Savings: @batch.ReadCarbonSavings().ToString("0.###") kg CO₂
                                </label>
                            </div>
                        }

                        <button class="btn btn-warning mt-2" type="submit">Mark Selected as Shipped</button>
                    }
                </form>
            </div>
        </div>
    </div>
</div>