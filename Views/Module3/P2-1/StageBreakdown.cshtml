@model ProRental.Domain.Module3.P2_1.Controls.CarbonReport
@{
    ViewData["Title"] = Model.ReturnRequestId.HasValue
        ? $"Carbon Report — Return #{Model.ReturnRequestId}"
        : "Carbon Report — All Returns";
}

<!-- Hero banner -->
<div class="carbon-hero p-4 mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <i class="bi bi-recycle fs-5"></i>
                <span class="opacity-75 small text-uppercase fw-semibold">Module 3 · Return Carbon Tracker</span>
            </div>
            <h2 class="fw-bold mb-1">Carbon Lifecycle Report</h2>
            <p class="mb-0 opacity-75">
                @if (Model.ReturnRequestId.HasValue)
                {
                    <span>Return Request <strong>#@Model.ReturnRequestId</strong> · </span>
                }
                @Model.Stages.Count stage(s) tracked
            </p>
        </div>
        @if (Model.HasHighCarbonStages)
        {
            <div class="d-flex align-items-center gap-2 bg-danger bg-opacity-25 rounded-3 px-3 py-2">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-5"></i>
                <div>
                    <div class="fw-semibold">High Carbon Alert</div>
                    <div class="small opacity-75">@Model.HighCarbonStageCount stage(s) exceeded threshold</div>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex align-items-center gap-2 bg-success bg-opacity-25 rounded-3 px-3 py-2">
                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                <div class="fw-semibold">All Stages Within Limits</div>
            </div>
        }
    </div>
</div>

<!-- Summary stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card carbon-stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-2 bg-primary bg-opacity-10">
                    <i class="bi bi-layers-fill text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Stages</div>
                    <div class="fw-bold fs-4">@Model.Stages.Count</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card carbon-stat-card h-100 border-0 shadow-sm @(Model.HasHighCarbonStages ? "border-danger border-opacity-50" : "")">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-3 p-2 @(Model.HasHighCarbonStages ? "bg-danger bg-opacity-10" : "bg-success bg-opacity-10")">
                        <i class="bi bi-cloud-haze2-fill @(Model.HasHighCarbonStages ? "text-danger" : "text-success") fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total CO₂ Emitted</div>
                        <div class="fw-bold fs-4">@Model.TotalCarbonKg.ToString("F3") <small class="fs-6 text-muted fw-normal">kg</small></div>
                    </div>
                </div>
                @if (Model.TotalCarbonKg > 0)
                {
                    <div class="carbon-bar mt-2" style="width: @(Math.Min(100, Model.TotalCarbonKg * 2))%"></div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card carbon-stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-2 bg-dark bg-opacity-10">
                    <i class="bi bi-cash-coin fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Carbon Surcharge</div>
                    <div class="fw-bold fs-4">$@Model.TotalSurcharge.ToString("F2")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Return ID filter -->
<div class="d-flex align-items-center gap-2 mb-3">
    <span class="text-muted small fw-semibold">Filter by Return ID:</span>
    <a asp-controller="ReturnStage" asp-action="StageBreakdown"
       class="btn btn-sm @(!Model.ReturnRequestId.HasValue ? "btn-dark" : "btn-outline-secondary")">
        All
    </a>
    <select class="form-select form-select-sm w-auto"
            onchange="if(this.value) window.location.href='@Url.Action("StageBreakdown","ReturnStage")?returnRequestId='+this.value">
        @if (!Model.ReturnRequestId.HasValue)
        {
            <option value="" disabled selected>Select Return ID…</option>
        }
        else
        {
            <option value="" disabled>Select Return ID…</option>
        }
        @foreach (var id in Model.AvailableReturnIds)
        {
            if (Model.ReturnRequestId == id)
            {
                <option value="@id" selected>#@id</option>
            }
            else
            {
                <option value="@id">#@id</option>
            }
        }
    </select>
</div>

<!-- Stage breakdown table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom d-flex align-items-center justify-content-between py-3">
        <h5 class="mb-0 fw-semibold"><i class="bi bi-table me-2 text-muted"></i>Stage Breakdown</h5>
        <span class="badge bg-secondary rounded-pill">@Model.Stages.Count stages</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Stage</th>
                    <th class="text-end"><i class="bi bi-lightning-charge text-warning me-1"></i>Energy</th>
                    <th class="text-end"><i class="bi bi-person text-primary me-1"></i>Labour</th>
                    <th class="text-end"><i class="bi bi-boxes text-secondary me-1"></i>Materials</th>
                    <th class="text-end"><i class="bi bi-droplet text-info me-1"></i>Water</th>
                    <th class="text-end"><i class="bi bi-bucket text-success me-1"></i>Cleaning</th>
                    <th class="text-end"><i class="bi bi-box-seam text-danger me-1"></i>Packaging</th>
                    <th class="text-end fw-semibold">Total CO₂ (kg)</th>
                    <th class="text-center">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.ReturnRequestId.HasValue)
                {
                    @* All view: group by stage type and show combined totals *@
                    var grouped = Model.Stages
                        .GroupBy(s => s.StageType)
                        .OrderBy(g => g.Key?.ToString());
                    @foreach (var group in grouped)
                    {
                        var energy    = group.Sum(s => s.EnergyCarbon);
                        var labour    = group.Sum(s => s.LabourCarbon);
                        var materials = group.Sum(s => s.MaterialsCarbon);
                        var water     = group.Sum(s => s.WaterCarbon);
                        var cleaning  = group.Sum(s => s.CleaningSuppliesCarbon);
                        var packaging = group.Sum(s => s.PackagingCarbon);
                        var total     = group.Sum(s => s.TotalCarbon);
                        var isHigh    = group.Any(s => s.IsHighCarbon);
                        var label     = group.FirstOrDefault()?.StageLabel ?? "Unknown";
                        var stageKey  = group.Key?.ToString() ?? "unknown";
                        <tr class="@(isHigh ? "high-carbon-row" : "")">
                            <td>
                                <span class="stage-badge stage-@stageKey">@label</span>
                                <span class="ms-1 text-muted small">×@group.Count()</span>
                            </td>
                            <td class="text-end text-muted small">@energy.ToString("F4")</td>
                            <td class="text-end text-muted small">@labour.ToString("F4")</td>
                            <td class="text-end text-muted small">@materials.ToString("F4")</td>
                            <td class="text-end text-muted small">@water.ToString("F4")</td>
                            <td class="text-end text-muted small">@cleaning.ToString("F4")</td>
                            <td class="text-end text-muted small">@packaging.ToString("F4")</td>
                            <td class="text-end fw-semibold">@total.ToString("F4")</td>
                            <td class="text-center">
                                @if (isHigh)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-exclamation-circle me-1"></i>High</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check2 me-1"></i>OK</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    @* Specific return ID: show each stage individually *@
                    @foreach (var stage in Model.Stages)
                    {
                        <tr class="@(stage.IsHighCarbon ? "high-carbon-row" : "")">
                            <td><span class="stage-badge stage-@stage.StageType">@stage.StageLabel</span></td>
                            <td class="text-end text-muted small">@stage.EnergyCarbon.ToString("F4")</td>
                            <td class="text-end text-muted small">@stage.LabourCarbon.ToString("F4")</td>
                            <td class="text-end text-muted small">@stage.MaterialsCarbon.ToString("F4")</td>
                            <td class="text-end text-muted small">@stage.WaterCarbon.ToString("F4")</td>
                            <td class="text-end text-muted small">@stage.CleaningSuppliesCarbon.ToString("F4")</td>
                            <td class="text-end text-muted small">@stage.PackagingCarbon.ToString("F4")</td>
                            <td class="text-end fw-semibold">@stage.TotalCarbon.ToString("F4")</td>
                            <td class="text-center">
                                @if (stage.IsHighCarbon)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-exclamation-circle me-1"></i>High</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check2 me-1"></i>OK</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="7" class="text-end text-muted fw-semibold">Total Carbon Emitted</td>
                    <td class="text-end fw-bold">@Model.TotalCarbonKg.ToString("F4")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Home
    </a>
</div>
